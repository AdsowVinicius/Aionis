<div class="min-h-screen bg-slate-50 flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <span class="text-3xl font-bold text-teal-600">Aionis</span>
    </div>

    <div class="bg-white rounded-2xl shadow-lg p-8">
      <h1 class="text-xl font-bold text-slate-900 mb-6">Redefinir senha</h1>

      <%= render "devise/shared/error_messages", resource: resource %>

      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
        <%= f.hidden_field :reset_password_token %>

        <div class="space-y-4">
          <div>
            <%= f.label :password, "Nova senha", class: "block text-sm font-medium text-slate-700 mb-1" %>
            <% if @minimum_password_length %>
              <p class="text-xs text-slate-400 mb-1">Mínimo <%= @minimum_password_length %> caracteres</p>
            <% end %>
            <%= f.password_field :password,
                  autofocus: true,
                  autocomplete: "new-password",
                  placeholder: "••••••••",
                  class: "block w-full rounded-lg border-0 py-2.5 px-3 text-slate-900 ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-teal-600 text-sm" %>
          </div>

          <div>
            <%= f.label :password_confirmation, "Confirmar nova senha", class: "block text-sm font-medium text-slate-700 mb-1" %>
            <%= f.password_field :password_confirmation,
                  autocomplete: "new-password",
                  placeholder: "••••••••",
                  class: "block w-full rounded-lg border-0 py-2.5 px-3 text-slate-900 ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-teal-600 text-sm" %>
          </div>

          <div class="pt-2">
            <%= f.submit "Redefinir senha",
                  class: "w-full bg-teal-600 hover:bg-teal-700 text-white font-semibold py-3 rounded-xl text-sm transition-colors cursor-pointer" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
