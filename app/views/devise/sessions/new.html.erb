<div class="min-h-screen bg-slate-50 flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <span class="text-3xl font-bold text-teal-600">Aionis</span>
      <p class="text-slate-500 text-sm mt-1">Seu assistente financeiro</p>
    </div>

    <div class="bg-white rounded-2xl shadow-lg p-8">
      <h1 class="text-xl font-bold text-slate-900 mb-6">Entrar na sua conta</h1>

      <%= render "devise/shared/error_messages", resource: resource %>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="space-y-4">
          <div>
            <%= f.label :email, "E-mail", class: "block text-sm font-medium text-slate-700 mb-1" %>
            <%= f.email_field :email,
                  autofocus: true,
                  autocomplete: "email",
                  placeholder: "seu@email.com",
                  class: "block w-full rounded-lg border-0 py-2.5 px-3 text-slate-900 ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-teal-600 text-sm" %>
          </div>

          <div>
            <%= f.label :password, "Senha", class: "block text-sm font-medium text-slate-700 mb-1" %>
            <%= f.password_field :password,
                  autocomplete: "current-password",
                  placeholder: "••••••••",
                  class: "block w-full rounded-lg border-0 py-2.5 px-3 text-slate-900 ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-teal-600 text-sm" %>
          </div>

          <% if devise_mapping.rememberable? %>
            <div class="flex items-center gap-2">
              <%= f.check_box :remember_me, class: "h-4 w-4 rounded border-slate-300 text-teal-600" %>
              <%= f.label :remember_me, "Lembrar de mim", class: "text-sm text-slate-600" %>
            </div>
          <% end %>

          <div class="pt-2">
            <%= f.submit "Entrar",
                  class: "w-full bg-teal-600 hover:bg-teal-700 text-white font-semibold py-3 rounded-xl text-sm transition-colors cursor-pointer" %>
          </div>
        </div>
      <% end %>

      <div class="mt-6 pt-5 border-t border-slate-100 space-y-2 text-center">
        <% if devise_mapping.recoverable? %>
          <p class="text-sm text-slate-500">
            <%= link_to "Esqueci minha senha", new_password_path(resource_name),
                  class: "text-teal-600 hover:text-teal-700 font-medium" %>
          </p>
        <% end %>
        <% if devise_mapping.registerable? %>
          <p class="text-sm text-slate-500">
            Não tem conta?
            <%= link_to "Criar conta grátis", new_registration_path(resource_name),
                  class: "text-teal-600 hover:text-teal-700 font-medium" %>
          </p>
        <% end %>
      </div>
    </div>
  </div>
</div>
