<div class="min-h-screen bg-slate-50 flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-md">
    <div class="text-center mb-8">
      <span class="text-3xl font-bold text-teal-600">Aionis</span>
      <p class="text-slate-500 text-sm mt-1">Seu assistente financeiro</p>
    </div>

    <div class="bg-white rounded-2xl shadow-lg p-8">
      <h1 class="text-xl font-bold text-slate-900 mb-6">Criar sua conta</h1>

      <%= render "devise/shared/error_messages", resource: resource %>

      <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
        <div class="space-y-4">
          <div>
            <%= f.label :name, "Nome completo", class: "block text-sm font-medium text-slate-700 mb-1" %>
            <%= f.text_field :name,
                  autofocus: true,
                  autocomplete: "name",
                  placeholder: "Seu nome",
                  class: "block w-full rounded-lg border-0 py-2.5 px-3 text-slate-900 ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-teal-600 text-sm" %>
          </div>

          <div>
            <%= f.label :email, "E-mail", class: "block text-sm font-medium text-slate-700 mb-1" %>
            <%# Pré-preenche com ?email= vindo da captura da landing (lead) %>
            <%= f.email_field :email,
                  value: resource.email.presence || params[:email],
                  autocomplete: "email",
                  placeholder: "seu@email.com",
                  class: "block w-full rounded-lg border-0 py-2.5 px-3 text-slate-900 ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-teal-600 text-sm" %>
          </div>

          <div>
            <%= f.label :password, "Senha", class: "block text-sm font-medium text-slate-700 mb-1" %>
            <% if @minimum_password_length %>
              <p class="text-xs text-slate-400 mb-1">Mínimo <%= @minimum_password_length %> caracteres</p>
            <% end %>
            <%= f.password_field :password,
                  autocomplete: "new-password",
                  placeholder: "••••••••",
                  class: "block w-full rounded-lg border-0 py-2.5 px-3 text-slate-900 ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-teal-600 text-sm" %>
          </div>

          <div>
            <%= f.label :password_confirmation, "Confirmar senha", class: "block text-sm font-medium text-slate-700 mb-1" %>
            <%= f.password_field :password_confirmation,
                  autocomplete: "new-password",
                  placeholder: "••••••••",
                  class: "block w-full rounded-lg border-0 py-2.5 px-3 text-slate-900 ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-teal-600 text-sm" %>
          </div>

          <div class="pt-2">
            <%= f.submit "Criar conta",
                  class: "w-full bg-teal-600 hover:bg-teal-700 text-white font-semibold py-3 rounded-xl text-sm transition-colors cursor-pointer" %>
          </div>
        </div>
      <% end %>

      <div class="mt-6 pt-5 border-t border-slate-100 text-center">
        <p class="text-sm text-slate-500">
          Já tem conta?
          <%= link_to "Entrar", new_session_path(resource_name),
                class: "text-teal-600 hover:text-teal-700 font-medium" %>
        </p>
      </div>
    </div>
  </div>
</div>
