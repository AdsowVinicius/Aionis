<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <title><%= content_for(:title) || "Aionis" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Aionis">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-slate-50 antialiased">
    <div class="flex h-screen overflow-hidden" data-controller="sidebar">

      <%# Overlay mobile — fecha o drawer ao clicar fora %>
      <div class="fixed inset-0 bg-black/50 z-20 hidden md:hidden"
           data-sidebar-target="overlay"
           data-action="click->sidebar#close"></div>

      <%# Sidebar — drawer no mobile, estática no desktop %>
      <div class="fixed inset-y-0 left-0 z-30 flex -translate-x-full transition-transform duration-200 ease-in-out md:relative md:translate-x-0 md:z-auto"
           data-sidebar-target="panel">
        <%= render "layouts/sidebar" %>
      </div>

      <div class="flex flex-col flex-1 overflow-hidden min-w-0">
        <%= render "layouts/topbar" %>

        <main class="flex-1 overflow-y-auto p-3 sm:p-4 md:p-6">
          <%# Coluna de conteúdo única e centralizada — mantém o conteúdo sempre
              no centro e proporcional em qualquer tamanho de tela. %>
          <div class="mx-auto w-full max-w-7xl">
            <%= render "layouts/flash" %>
            <%= yield %>
          </div>
        </main>
      </div>

    </div>
  </body>
</html>
