<%# Topbar (Figma): contexto do workspace + título, busca, sino, usuário. %>
<header class="h-16 bg-white border-b border-border px-4 md:px-8 flex items-center justify-between shrink-0 sticky top-0 z-10">
  <div class="flex items-center gap-3 min-w-0">
    <%# Hamburger — só mobile (abre o drawer) %>
    <button type="button"
            class="md:hidden p-2 rounded-lg text-mist hover:text-ink hover:bg-cream transition-colors shrink-0"
            data-action="click->sidebar#open"
            aria-label="Abrir menu">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" /></svg>
    </button>

    <div class="min-w-0">
      <% if current_workspace %>
        <div class="text-xs text-mist truncate"><%= current_workspace.name %> · <%= workspace_kind_label(current_workspace) %></div>
      <% end %>
      <div class="font-display font-semibold text-ink truncate"><%= content_for(:page_title) || "Aionis" %></div>
    </div>
  </div>

  <div class="flex items-center gap-2 md:gap-4 shrink-0">
    <% if current_workspace %>
      <%# Busca real: cai na listagem de lançamentos com o filtro q %>
      <%= form_with url: workspace_financial_transactions_path(current_workspace), method: :get, class: "relative hidden lg:block" do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.7" stroke="currentColor" class="w-4 h-4 absolute left-3 top-1/2 -translate-y-1/2 text-mist pointer-events-none"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z" /></svg>
        <input type="search" name="q" placeholder="Buscar fornecedor, documento, valor…" aria-label="Buscar lançamentos"
               class="h-10 w-72 xl:w-80 pl-9 pr-4 rounded-[14px] bg-cream border border-transparent focus:border-teal outline-none text-sm transition" />
      <% end %>

      <%# Sino → alertas (ponto teal quando há alerta crítico real) %>
      <%= link_to workspace_alerts_path(current_workspace), aria: { label: "Alertas" },
            class: "relative w-10 h-10 rounded-[14px] bg-cream flex items-center justify-center hover:bg-[#E8F4EF] transition-colors" do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.7" stroke="currentColor" class="w-4 h-4 text-ink"><path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0" /></svg>
        <% if respond_to?(:workspace_critical_alerts_count) && workspace_critical_alerts_count.to_i.positive? %>
          <span class="absolute top-2 right-2 w-2 h-2 rounded-full bg-teal"></span>
        <% end %>
      <% end %>
    <% end %>

    <div class="flex items-center gap-3 pl-3 border-l border-border">
      <div class="w-9 h-9 rounded-full bg-gradient-to-br from-teal to-ink flex items-center justify-center text-white text-xs font-semibold shrink-0">
        <%= user_initials(current_user) %>
      </div>
      <div class="text-sm hidden sm:block">
        <div class="font-semibold leading-tight text-ink truncate max-w-[140px]"><%= current_user.name %></div>
        <div class="text-xs text-mist leading-tight"><%= current_workspace ? current_workspace_role : "Conta" %></div>
      </div>
    </div>
  </div>
</header>
