<%# Sidebar navy (AppShell do Figma) — bg --sidebar #0B1A2F, 260px.
    Itens principais seguem o Figma; "Mais" agrupa telas já existentes do app
    que o Figma não cobre (não podem ficar inacessíveis). %>
<aside class="w-[260px] shrink-0 h-screen bg-sidebar text-white p-5 flex flex-col gap-1 overflow-y-auto">

  <%# Logo mono (Figma Logo mono) %>
  <%= link_to current_workspace ? workspace_dashboard_path(current_workspace) : workspaces_path, class: "px-2 mb-6 flex items-center gap-2" do %>
    <span class="relative flex items-center justify-center rounded-[14px] w-7 h-7 bg-white/10">
      <svg viewBox="0 0 24 24" width="17" height="17" fill="none"><path d="M4 18 L12 4 L20 18" stroke="#14B88A" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"/><path d="M8 14 L16 14" stroke="#fff" stroke-width="2.4" stroke-linecap="round"/></svg>
    </span>
    <span class="font-display text-white" style="font-weight:800;font-size:1.05rem">Aionis</span>
  <% end %>

  <% if current_workspace %>
    <div class="text-[10px] uppercase tracking-wider text-white/40 px-3 mb-2">Navegação</div>

    <%= sidebar_nav_link "Dashboard", workspace_dashboard_path(current_workspace), match: :exact do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.7" stroke="currentColor" class="w-[17px] h-[17px] shrink-0"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" /></svg>
    <% end %>

    <%= sidebar_nav_link "Documentos", workspace_documents_path(current_workspace) do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.7" stroke="currentColor" class="w-[17px] h-[17px] shrink-0"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>
    <% end %>

    <%= sidebar_nav_link "Lançamentos", workspace_financial_transactions_path(current_workspace) do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.7" stroke="currentColor" class="w-[17px] h-[17px] shrink-0"><path stroke-linecap="round" stroke-linejoin="round" d="M3 6.75h18M3 12h18m-9 5.25h9" /></svg>
    <% end %>

    <%= sidebar_nav_link "Contas", workspace_payables_path(current_workspace) do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.7" stroke="currentColor" class="w-[17px] h-[17px] shrink-0"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z" /></svg>
    <% end %>

    <%= sidebar_nav_link "Assistente", workspace_chat_path(current_workspace) do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.7" stroke="currentColor" class="w-[17px] h-[17px] shrink-0"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456z" /></svg>
    <% end %>

    <%= sidebar_nav_link "Configurações", workspace_settings_path(current_workspace) do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.7" stroke="currentColor" class="w-[17px] h-[17px] shrink-0"><path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
    <% end %>

    <%# Telas existentes fora do Figma — mantidas acessíveis %>
    <div class="text-[10px] uppercase tracking-wider text-white/40 px-3 mt-5 mb-2">Mais</div>
    <% {
      "Alertas"        => workspace_alerts_path(current_workspace),
      "Fornecedores"   => workspace_counterparties_path(current_workspace),
      "Categorias"     => workspace_categories_path(current_workspace),
      "Regras"         => workspace_category_rules_path(current_workspace),
      "Conciliação"    => workspace_reconciliations_path(current_workspace),
      "WhatsApp"       => workspace_whatsapp_channels_path(current_workspace),
      "Auditoria"      => workspace_audit_logs_path(current_workspace)
    }.each do |label, path| %>
      <%= sidebar_nav_link label, path do %>
        <span class="w-[17px] h-[17px] shrink-0 flex items-center justify-center"><span class="w-1.5 h-1.5 rounded-full bg-white/30"></span></span>
      <% end %>
    <% end %>

    <%# Card de plano (dados reais da assinatura; sem assinatura = beta) %>
    <div class="mt-auto pt-5">
      <div class="rounded-[14px] bg-white/5 p-4 border border-white/5">
        <% if (plan = sidebar_plan) %>
          <div class="flex items-center gap-2 text-xs text-teal font-semibold">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" /></svg>
            Plano <%= plan[:name] %>
          </div>
          <div class="text-xs text-white/60 mt-1"><%= plan[:used] %> / <%= plan[:limit] %> documentos</div>
          <div class="h-1.5 bg-white/10 rounded-full mt-2 overflow-hidden">
            <div class="h-full bg-teal rounded-full" style="width: <%= plan[:pct] %>%"></div>
          </div>
        <% else %>
          <div class="flex items-center gap-2 text-xs text-teal font-semibold">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" /></svg>
            Beta · preço de fundador
          </div>
          <div class="text-xs text-white/60 mt-1">Sem assinatura ativa</div>
        <% end %>
        <%= link_to "Fazer upgrade", root_path(anchor: "planos"),
              class: "mt-3 w-full text-xs h-8 rounded-lg bg-teal hover:bg-[#0ea273] text-white flex items-center justify-center font-semibold transition-colors" %>
      </div>

      <%= button_to destroy_user_session_path, method: :delete, data: { turbo: false },
            class: "mt-3 flex items-center gap-2 text-xs text-white/50 hover:text-white px-3 bg-transparent" do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.7" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-6a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 007.5 21h6a2.25 2.25 0 002.25-2.25V15M12 9l-3 3m0 0l3 3m-3-3h12.75" /></svg>
        Sair
      <% end %>
    </div>
  <% else %>
    <%= sidebar_nav_link "Meus workspaces", workspaces_path do %>
      <span class="w-[17px] h-[17px]"></span>
    <% end %>
  <% end %>
</aside>
