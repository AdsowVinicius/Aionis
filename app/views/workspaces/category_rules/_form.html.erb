<%= form_with model: [current_workspace, @rule] do |f| %>
  <% if @rule.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
      <p class="text-sm font-medium text-red-700 mb-1">
        <%= pluralize(@rule.errors.count, "erro encontrado", "erros encontrados") %>:
      </p>
      <ul class="list-disc list-inside text-sm text-red-600 space-y-0.5">
        <% @rule.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="space-y-5">

    <%# Nome %>
    <div>
      <div class="flex items-center justify-between mb-1">
        <%= f.label :name, "Nome da regra", class: "text-sm font-medium text-slate-700" %>
        <span class="text-xs text-red-500">Obrigatório</span>
      </div>
      <%= f.text_field :name,
            class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent",
            placeholder: "Ex.: Combustível dos entregadores" %>
    </div>

    <%# Categoria de destino %>
    <div>
      <div class="flex items-center justify-between mb-1">
        <%= f.label :category_id, "Categoria a aplicar", class: "text-sm font-medium text-slate-700" %>
        <span class="text-xs text-slate-400">Recomendado</span>
      </div>
      <%= f.select :category_id,
            [["— Nenhuma —", ""]] + @categories.map { |c| [c.name, c.id] },
            { selected: @rule.category_id },
            class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent bg-white" %>
    </div>

    <%# Natureza %>
    <div>
      <%= f.label :kind, "Natureza do lançamento", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.select :kind,
            [["Qualquer", ""], ["Despesa", "expense"], ["Receita", "income"]],
            { selected: @rule.kind },
            class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent bg-white" %>
    </div>

    <%# --- Condições de casamento --- %>
    <div class="pt-2 border-t border-slate-100">
      <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-1">Condições</p>
      <p class="text-xs text-slate-400 mb-3">Informe ao menos uma. A regra só é aplicada quando <strong>todas</strong> as condições preenchidas casarem.</p>

      <div class="space-y-4">
        <%# Palavras-chave %>
        <div>
          <%= f.label :keywords, "Palavras-chave na descrição", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.text_field :keywords,
                class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent",
                placeholder: "posto, gasolina, combustivel" %>
          <p class="text-xs text-slate-400 mt-1">Separe por vírgula. Ignora acentos e maiúsculas.</p>
        </div>

        <%# CPF/CNPJ %>
        <div>
          <div class="flex items-center justify-between mb-1">
            <%= f.label :tax_id, "CPF/CNPJ do fornecedor", class: "text-sm font-medium text-slate-700" %>
            <span class="text-xs text-slate-400">Opcional</span>
          </div>
          <%= f.text_field :tax_id,
                class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent",
                placeholder: "Informe se souber" %>
        </div>

        <%# Fornecedor %>
        <div>
          <div class="flex items-center justify-between mb-1">
            <%= f.label :counterparty_id, "Fornecedor/cliente", class: "text-sm font-medium text-slate-700" %>
            <span class="text-xs text-slate-400">Opcional</span>
          </div>
          <%= f.select :counterparty_id,
                [["— Nenhum —", ""]] + @counterparties.map { |c| [c.name, c.id] },
                { selected: @rule.counterparty_id },
                class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent bg-white" %>
        </div>
      </div>
    </div>

    <%# --- Classificação aplicada --- %>
    <div class="pt-2 border-t border-slate-100">
      <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-3">Classificação aplicada</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <%= f.label :cost_type, "Tipo de custo", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.select :cost_type,
                [["— Da categoria —", ""], ["Fixo", "fixed"], ["Variável", "variable"],
                 ["Semivariável", "semi_variable"], ["Pontual", "one_time"]],
                { selected: @rule.cost_type },
                class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent bg-white" %>
        </div>

        <div>
          <%= f.label :essentiality, "Essencialidade", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.select :essentiality,
                [["— Da categoria —", ""], ["Essencial", "essential"],
                 ["Importante operacional", "operational_important"],
                 ["Não essencial", "non_essential"], ["Supérfluo", "superfluous"], ["Revisar", "review"]],
                { selected: @rule.essentiality },
                class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent bg-white" %>
        </div>

        <div>
          <%= f.label :scope, "Escopo", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.select :scope,
                [["— Nenhum —", ""], ["Pessoal", "personal"], ["Empresarial", "business"],
                 ["Misto", "mixed"], ["Revisar", "review"]],
                { selected: @rule.scope },
                class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent bg-white" %>
        </div>

        <div>
          <%= f.label :recurrence, "Recorrência", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.select :recurrence,
                [["— Nenhuma —", ""], ["Recorrente", "recurring"], ["Ocasional", "occasional"], ["Pontual", "one_off"]],
                { selected: @rule.recurrence },
                class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent bg-white" %>
        </div>

        <div>
          <%= f.label :cost_center, "Centro de custo", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.text_field :cost_center,
                class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent",
                placeholder: "Opcional" %>
        </div>

        <div>
          <%= f.label :confidence, "Confiança (0–100)", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.number_field :confidence, in: 0..100, step: 1,
                class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent" %>
        </div>

        <div>
          <%= f.label :priority, "Prioridade", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.number_field :priority, step: 1,
                class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent" %>
          <p class="text-xs text-slate-400 mt-1">Maior prioridade vence em caso de empate.</p>
        </div>
      </div>

      <label class="flex items-center gap-2 mt-4 cursor-pointer">
        <%= f.check_box :active, class: "rounded border-slate-300 text-teal-600 focus:ring-teal-500" %>
        <span class="text-sm text-slate-700">Regra ativa</span>
      </label>
    </div>

  </div>

  <div class="flex items-center gap-3 mt-6 pt-5 border-t border-slate-100">
    <%= f.submit(@rule.persisted? ? "Salvar alterações" : "Criar regra",
          class: "px-5 py-2 bg-teal-600 text-white text-sm font-semibold rounded-lg hover:bg-teal-700 transition-colors cursor-pointer") %>
    <%= link_to "Cancelar", workspace_category_rules_path(current_workspace),
          class: "px-4 py-2 text-sm text-slate-500 hover:text-slate-700 transition-colors" %>
  </div>
<% end %>
