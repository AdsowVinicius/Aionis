<%
  form_url = @channel.persisted? ?
    workspace_whatsapp_channel_path(current_workspace, @channel) :
    workspace_whatsapp_channels_path(current_workspace)
%>
<%= form_with model: @channel, scope: :workspace_channel, url: form_url,
      method: (@channel.persisted? ? :patch : :post) do |f| %>
  <% if @channel.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
      <p class="text-sm font-medium text-red-700 mb-1">
        <%= pluralize(@channel.errors.count, "erro encontrado", "erros encontrados") %>:
      </p>
      <ul class="list-disc list-inside text-sm text-red-600 space-y-0.5">
        <% @channel.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="space-y-5">
    <%# Provedor %>
    <div>
      <%= f.label :provider, "Provedor", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.select :provider,
            [["Meta Cloud API (oficial)", "meta_cloud"], ["Evolution API", "evolution"]],
            { selected: @channel.provider || "meta_cloud" },
            class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent bg-white" %>
      <p class="text-xs text-slate-400 mt-1">Meta Cloud é a API oficial do WhatsApp Business.</p>
    </div>

    <%# --- Meta Cloud --- %>
    <div class="pt-2 border-t border-slate-100">
      <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-3">Credenciais Meta Cloud</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div>
          <%= f.label :phone_number_id, "Phone Number ID", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.text_field :phone_number_id,
                class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent",
                placeholder: "Ex.: 1234567890" %>
        </div>
        <div>
          <%= f.label :business_account_id, "Business Account ID", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.text_field :business_account_id,
                class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent" %>
        </div>
        <div>
          <%= f.label :display_phone_number, "Número exibido", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.text_field :display_phone_number,
                class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent",
                placeholder: "+55 11 99999-0000" %>
        </div>
        <div>
          <%= f.label :verify_token, "Verify token", class: "block text-sm font-medium text-slate-700 mb-1" %>
          <%= f.text_field :verify_token,
                class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent" %>
        </div>
      </div>

      <div class="mt-4">
        <%= f.label :access_token, "Access token", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.password_field :access_token, autocomplete: "off",
              value: nil,
              class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent",
              placeholder: @channel.persisted? ? "•••••••• (deixe em branco para manter)" : "Token permanente da Meta" %>
        <p class="text-xs text-slate-400 mt-1">Guardado criptografado. <% if @channel.persisted? %>Preencha apenas para rotacionar.<% end %></p>
      </div>
    </div>

    <%# --- Evolution --- %>
    <div class="pt-2 border-t border-slate-100">
      <p class="text-xs font-semibold text-slate-500 uppercase tracking-wider mb-3">Evolution (opcional)</p>
      <div>
        <%= f.label :instance, "Instância", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.text_field :instance,
              class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent",
              placeholder: "Só para provedor Evolution" %>
      </div>
    </div>
  </div>

  <div class="flex items-center gap-3 mt-6 pt-5 border-t border-slate-100">
    <%= f.submit(@channel.persisted? ? "Salvar alterações" : "Conectar canal",
          class: "px-5 py-2 bg-teal-600 text-white text-sm font-semibold rounded-lg hover:bg-teal-700 transition-colors cursor-pointer") %>
    <%= link_to "Cancelar", workspace_whatsapp_channels_path(current_workspace),
          class: "px-4 py-2 text-sm text-slate-500 hover:text-slate-700 transition-colors" %>
  </div>
<% end %>
