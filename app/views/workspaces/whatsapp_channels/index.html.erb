<% content_for :title, "Canais WhatsApp — #{current_workspace.name}" %>
<% content_for :page_title, "Canais WhatsApp" %>

<div class="max-w-5xl">

  <%# Cabeçalho %>
  <div class="flex items-start sm:items-center justify-between mb-4 md:mb-6 gap-3">
    <div>
      <h2 class="text-lg md:text-xl font-bold text-slate-900">Canais WhatsApp</h2>
      <p class="text-slate-500 text-sm mt-0.5 hidden sm:block">Conecte o WhatsApp Business da empresa para receber comprovantes por mensagem.</p>
    </div>
    <%= link_to new_workspace_whatsapp_channel_path(current_workspace),
          class: "shrink-0 inline-flex items-center gap-2 px-3 md:px-4 py-2 bg-teal-600 text-white text-sm font-semibold rounded-lg hover:bg-teal-700 transition-colors" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
      </svg>
      <span class="hidden sm:inline">Conectar canal</span>
      <span class="sm:hidden">Conectar</span>
    <% end %>
  </div>

  <%# Instruções de webhook (Meta) %>
  <div class="bg-slate-50 border border-slate-200 rounded-xl p-4 mb-4 md:mb-6">
    <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-2">Configuração na Meta</p>
    <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-2 text-sm">
      <div>
        <dt class="text-xs text-slate-400">URL de callback do webhook</dt>
        <dd class="text-slate-800 font-mono text-xs break-all"><%= whatsapp_meta_verify_url %></dd>
      </div>
      <div>
        <dt class="text-xs text-slate-400">Campo a assinar</dt>
        <dd class="text-slate-800"><code>messages</code></dd>
      </div>
    </dl>
    <p class="text-xs text-slate-400 mt-2">O <em>verify token</em> e o <em>app secret</em> ficam nas variáveis de ambiente do servidor.</p>
  </div>

  <%# Tabela / Estado vazio %>
  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <% if @channels.empty? %>
      <div class="p-8 md:p-12 text-center">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" class="w-12 h-12 text-slate-300 mx-auto mb-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 9.75a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" />
        </svg>
        <h3 class="text-base font-semibold text-slate-700 mb-1">Nenhum canal conectado</h3>
        <p class="text-sm text-slate-500 mb-4">Conecte o WhatsApp Business da empresa para começar a receber comprovantes.</p>
        <%= link_to "Conectar canal", new_workspace_whatsapp_channel_path(current_workspace),
              class: "inline-flex items-center gap-2 px-4 py-2 bg-teal-600 text-white text-sm font-semibold rounded-lg hover:bg-teal-700 transition-colors" %>
      </div>
    <% else %>
      <div class="divide-y divide-slate-100">
        <% @channels.each do |channel| %>
          <div class="px-4 py-4 flex items-start justify-between gap-3">
            <div class="min-w-0">
              <div class="flex items-center gap-2 mb-0.5">
                <p class="font-medium text-slate-800 text-sm truncate">
                  <%= channel.display_phone_number.presence || channel.phone_number_id.presence || channel.instance.presence || "Canal ##{channel.id}" %>
                </p>
                <%= whatsapp_channel_status_badge(channel) %>
              </div>
              <p class="text-xs text-slate-400">
                <%= channel.provider == "meta_cloud" ? "Meta Cloud API" : channel.provider.to_s.humanize %>
                <% if channel.phone_number_id.present? %><span class="mx-1">·</span>ID <%= channel.phone_number_id %><% end %>
                <% if channel.last_event_at %><span class="mx-1">·</span>último evento <%= channel.last_event_at.strftime("%d/%m %H:%M") %><% end %>
              </p>
            </div>
            <div class="shrink-0 flex items-center gap-3">
              <%= link_to "Editar", edit_workspace_whatsapp_channel_path(current_workspace, channel),
                    class: "text-xs font-medium text-teal-600 hover:text-teal-700" %>
              <%= button_to workspace_whatsapp_channel_path(current_workspace, channel),
                    method: :delete,
                    form: { data: { turbo_confirm: "Remover este canal? As mensagens vinculadas serão apagadas." } },
                    class: "text-xs text-slate-400 hover:text-red-500 cursor-pointer bg-transparent border-0 p-0" do %>
                Remover
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

</div>
