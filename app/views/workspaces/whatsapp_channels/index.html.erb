<% content_for :title, "WhatsApp — #{current_workspace.name}" %>
<% content_for :page_title, "WhatsApp" %>

<div class="max-w-3xl space-y-4 md:space-y-6">

  <%# Cabeçalho %>
  <div>
    <h2 class="text-lg md:text-xl font-bold text-slate-900">WhatsApp</h2>
    <p class="text-slate-500 text-sm mt-0.5">
      Envie fotos ou PDFs de comprovantes direto para o WhatsApp do Aionis e nós
      registramos o lançamento pra você.
    </p>
  </div>

  <%# Status do número global (configurado pela equipe Aionis via servidor) %>
  <div class="bg-white rounded-xl border border-slate-200 p-4 md:p-6">
    <div class="flex items-center justify-between gap-3">
      <div>
        <p class="text-xs font-semibold text-slate-400 uppercase tracking-wide">Canal Aionis</p>
        <p class="text-sm text-slate-800 mt-1">
          <%= @provider_key == "meta_cloud" ? "WhatsApp Cloud API (Meta)" : @provider_key.to_s.humanize %>
        </p>
      </div>
      <% if @provider_ready %>
        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium border bg-teal-50 text-teal-700 border-teal-200">
          Ativo
        </span>
      <% else %>
        <span class="inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium border bg-amber-50 text-amber-700 border-amber-200">
          Indisponível
        </span>
      <% end %>
    </div>
    <% unless @provider_ready %>
      <p class="text-xs text-slate-400 mt-3">
        O canal ainda não foi ativado no servidor. Fale com o suporte do Aionis.
      </p>
    <% end %>
  </div>

  <%# Registro do número do próprio cliente (identifica o remetente) %>
  <div class="bg-white rounded-xl border border-slate-200 p-4 md:p-6">
    <p class="text-sm font-semibold text-slate-700 mb-1">Seu número de WhatsApp</p>
    <p class="text-xs text-slate-500 mb-4">
      Cadastre o número de onde você vai enviar os comprovantes. É assim que o
      Aionis reconhece que a mensagem é sua. <span class="text-slate-400">(opcional)</span>
    </p>

    <%= form_with model: current_workspace, class: "flex flex-col sm:flex-row gap-3 sm:items-end" do |f| %>
      <div class="flex-1">
        <%= f.label :whatsapp_number, "Número (com DDD)", class: "block text-xs font-medium text-slate-600 mb-1" %>
        <%= f.telephone_field :whatsapp_number,
              value: current_workspace.whatsapp_number,
              placeholder: "55 11 99999-9999",
              class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-teal-500" %>
      </div>
      <%= f.submit "Salvar número",
            class: "px-4 py-2 bg-teal-600 text-white text-sm font-semibold rounded-lg hover:bg-teal-700 transition-colors cursor-pointer" %>
    <% end %>

    <% if current_workspace.whatsapp_number.present? %>
      <p class="text-xs text-teal-600 mt-3">
        ✓ Número cadastrado. Mensagens vindas dele entram automaticamente neste workspace.
      </p>
    <% end %>
  </div>

  <%# Atividade recente do canal %>
  <div class="bg-white rounded-xl border border-slate-200 p-4 md:p-6">
    <p class="text-sm font-semibold text-slate-700 mb-3">Atividade</p>
    <% if @last_incoming_at %>
      <p class="text-sm text-slate-600">
        Última mensagem recebida em <%= @last_incoming_at.strftime("%d/%m/%Y às %H:%M") %>.
      </p>
    <% else %>
      <p class="text-sm text-slate-500">Nenhuma mensagem recebida ainda.</p>
    <% end %>
    <% if @channels.any? %>
      <ul class="mt-3 space-y-1">
        <% @channels.each do |channel| %>
          <li class="text-xs text-slate-400">
            <%= channel.provider == "meta_cloud" ? "Meta Cloud API" : channel.provider.to_s.humanize %>
            · <%= whatsapp_channel_status_badge(channel) %>
            <% if channel.last_event_at %>· último evento <%= channel.last_event_at.strftime("%d/%m %H:%M") %><% end %>
          </li>
        <% end %>
      </ul>
    <% end %>
  </div>

</div>
