<% content_for :title, "Conciliação — #{current_workspace.name}" %>
<% content_for :page_title, "Conciliação bancária" %>

<div class="max-w-5xl">

  <div class="mb-4 md:mb-6">
    <h2 class="text-lg md:text-xl font-bold text-slate-900">Conciliação bancária</h2>
    <p class="text-slate-500 text-sm mt-0.5 hidden sm:block">Revise as correspondências entre suas transações bancárias e os lançamentos do Aionis.</p>
  </div>

  <%# Filtros por status %>
  <div class="flex flex-wrap gap-2 mb-4">
    <% [["suggested", "Sugeridas"], ["confirmed", "Confirmadas"], ["rejected", "Rejeitadas"]].each do |value, label| %>
      <%= link_to workspace_reconciliations_path(current_workspace, status: value),
            class: "px-3 py-1.5 rounded-lg text-sm font-medium border transition-colors #{@status == value ? 'bg-teal-600 text-white border-teal-600' : 'bg-white text-slate-600 border-slate-300 hover:bg-slate-50'}" do %>
        <%= label %>
        <span class="ml-1 text-xs opacity-70"><%= @counts[value].to_i %></span>
      <% end %>
    <% end %>
  </div>

  <% if @matches.empty? %>
    <div class="bg-white rounded-xl border border-slate-200 p-8 md:p-12 text-center">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" class="w-12 h-12 text-slate-300 mx-auto mb-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
      </svg>
      <h3 class="text-base font-semibold text-slate-700 mb-1">Nada por aqui</h3>
      <p class="text-sm text-slate-500">
        <% if @status == "suggested" %>
          Nenhuma sugestão de conciliação no momento. Conecte uma conta via Open Finance para sincronizar transações.
        <% else %>
          Nenhuma conciliação <%= @status == "confirmed" ? "confirmada" : "rejeitada" %> ainda.
        <% end %>
      </p>
    </div>
  <% else %>
    <div class="space-y-3">
      <% @matches.each do |match| %>
        <% bt = match.bank_transaction %>
        <% ft = match.financial_transaction %>
        <% tier_label, tier_css = confidence_tier(match.score) %>
        <div class="bg-white rounded-xl border border-slate-200 p-4">
          <div class="flex items-center justify-between mb-3">
            <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium border <%= tier_css %>">
              Confiança <%= tier_label.downcase %> · <%= match.score %>
            </span>
            <span class="text-xs text-slate-400"><%= match.reasons.to_a.join(" · ") %></span>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-[1fr_auto_1fr] items-center gap-3">
            <%# Transação bancária %>
            <div class="min-w-0">
              <p class="text-xs text-slate-400 mb-0.5">Transação bancária</p>
              <p class="text-sm font-medium text-slate-800 truncate"><%= bt.description.presence || "—" %></p>
              <p class="text-xs text-slate-500">
                <%= bt.posted_on&.strftime("%d/%m/%Y") %>
                <span class="mx-1">·</span>
                <span class="<%= bt.direction == 'credit' ? 'text-teal-600' : 'text-red-600' %> font-medium">
                  <%= bt.direction == "credit" ? "+" : "−" %><%= format_brl(bt.amount_cents) %>
                </span>
              </p>
            </div>

            <div class="hidden sm:flex items-center justify-center text-slate-300">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5" />
              </svg>
            </div>

            <%# Lançamento %>
            <div class="min-w-0 sm:text-right">
              <p class="text-xs text-slate-400 mb-0.5">Lançamento no Aionis</p>
              <p class="text-sm font-medium text-slate-800 truncate"><%= ft.description %></p>
              <p class="text-xs text-slate-500">
                <%= ft.transacted_on&.strftime("%d/%m/%Y") %>
                <% if ft.category %><span class="mx-1">·</span><%= ft.category.name %><% end %>
                <span class="mx-1">·</span><%= format_brl(ft.amount_cents) %>
              </p>
            </div>
          </div>

          <% if match.suggested? %>
            <div class="flex items-center gap-2 mt-4 pt-3 border-t border-slate-100">
              <%= button_to confirm_workspace_reconciliation_path(current_workspace, match),
                    method: :patch,
                    class: "inline-flex items-center gap-1.5 px-3 py-1.5 bg-teal-600 text-white text-sm font-semibold rounded-lg hover:bg-teal-700 transition-colors cursor-pointer" do %>
                Confirmar
              <% end %>
              <%= button_to reject_workspace_reconciliation_path(current_workspace, match),
                    method: :patch,
                    class: "inline-flex items-center gap-1.5 px-3 py-1.5 bg-white border border-slate-300 text-slate-600 text-sm font-medium rounded-lg hover:bg-slate-50 transition-colors cursor-pointer" do %>
                Rejeitar
              <% end %>
            </div>
          <% else %>
            <div class="mt-3 pt-3 border-t border-slate-100">
              <span class="text-xs font-medium <%= match.confirmed? ? 'text-teal-600' : 'text-slate-400' %>">
                <%= match.confirmed? ? "✓ Conciliação confirmada" : "Sugestão rejeitada" %>
                <% if match.matched_by == "user" %> (por você)<% end %>
              </span>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>

</div>
