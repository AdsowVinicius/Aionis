<%= form_with model: [current_workspace, @category] do |f| %>
  <% if @category.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
      <p class="text-sm font-medium text-red-700 mb-1">
        <%= pluralize(@category.errors.count, "erro encontrado", "erros encontrados") %>:
      </p>
      <ul class="list-disc list-inside text-sm text-red-600 space-y-0.5">
        <% @category.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="space-y-5">

    <%# Nome %>
    <div>
      <div class="flex items-center justify-between mb-1">
        <%= f.label :name, "Nome", class: "text-sm font-medium text-slate-700" %>
        <span class="text-xs text-red-500">Obrigatório</span>
      </div>
      <%= f.text_field :name,
            class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent",
            placeholder: "Nome da categoria" %>
    </div>

    <%# Tipo / Natureza %>
    <div>
      <div class="flex items-center justify-between mb-1">
        <%= f.label :kind, "Natureza", class: "text-sm font-medium text-slate-700" %>
        <span class="text-xs text-red-500">Obrigatório</span>
      </div>
      <%= f.select :kind,
            [["Receita", "income"], ["Despesa", "expense"], ["Transferência", "transfer"]],
            { include_blank: "Selecione a natureza" },
            class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent bg-white" %>
    </div>

    <%# Categoria pai %>
    <div>
      <div class="flex items-center justify-between mb-1">
        <%= f.label :parent_id, "Categoria pai", class: "text-sm font-medium text-slate-700" %>
        <span class="text-xs text-slate-400">Opcional</span>
      </div>
      <%= f.select :parent_id,
            [["— Nenhuma —", ""]] + @parent_options.map { |c| [c.name, c.id] },
            { selected: @category.parent_id },
            class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent bg-white" %>
    </div>

    <%# Tipo de custo %>
    <div>
      <div class="flex items-center justify-between mb-1">
        <%= f.label :cost_type, "Tipo de custo", class: "text-sm font-medium text-slate-700" %>
        <span class="text-xs text-slate-400">Opcional</span>
      </div>
      <%= f.select :cost_type,
            [["— Nenhum —", ""], ["Fixo", "fixed"], ["Variável", "variable"],
             ["Semivariável", "semi_variable"], ["Pontual", "one_time"]],
            { selected: @category.cost_type },
            class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent bg-white" %>
    </div>

    <%# Essencialidade %>
    <div>
      <div class="flex items-center justify-between mb-1">
        <%= f.label :essentiality, "Essencialidade", class: "text-sm font-medium text-slate-700" %>
        <span class="text-xs text-slate-400">Opcional</span>
      </div>
      <%= f.select :essentiality,
            [["— Nenhuma —", ""], ["Essencial", "essential"],
             ["Importante operacional", "operational_important"],
             ["Não essencial", "non_essential"], ["Supérfluo", "superfluous"], ["Revisar", "review"]],
            { selected: @category.essentiality },
            class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent bg-white" %>
    </div>

  </div>

  <div class="flex items-center gap-3 mt-6 pt-5 border-t border-slate-100">
    <%= f.submit(@category.persisted? ? "Salvar alterações" : "Criar categoria",
          class: "px-5 py-2 bg-teal-600 text-white text-sm font-semibold rounded-lg hover:bg-teal-700 transition-colors cursor-pointer") %>
    <%= link_to "Cancelar",
          (@category.persisted? ? workspace_category_path(current_workspace, @category) : workspace_categories_path(current_workspace)),
          class: "px-4 py-2 text-sm text-slate-500 hover:text-slate-700 transition-colors" %>
  </div>
<% end %>
