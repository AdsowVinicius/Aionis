<%# Card KPI (Figma Kpi). locals: label, value, icon_path, delta (nil ok), highlight %>
<% highlight = local_assigns.fetch(:highlight, false)
   delta     = local_assigns[:delta] %>
<div class="rounded-[20px] p-5 border <%= highlight ? "bg-ink text-white border-ink" : "bg-white border-border" %>">
  <div class="flex items-center justify-between">
    <div class="text-xs <%= highlight ? "text-white/60" : "text-mist" %>"><%= label %></div>
    <div class="w-8 h-8 rounded-lg flex items-center justify-center <%= highlight ? "bg-teal/20 text-teal" : "bg-[#E8F4EF] text-teal" %>">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="<%= icon_path %>" /></svg>
    </div>
  </div>
  <div class="font-display text-2xl mt-3"><%= value %></div>
  <% if delta %>
    <div class="text-xs mt-1 flex items-center gap-1 <%= delta[:pct] >= 0 ? "text-teal" : "text-rose" %>">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3 h-3"><path stroke-linecap="round" stroke-linejoin="round" d="<%= delta[:pct] >= 0 ? "M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" : "M4.5 4.5l15 15m0 0V8.25m0 11.25H8.25" %>" /></svg>
      <%= delta[:text] %>
      <span class="<%= highlight ? "text-white/40" : "text-mist" %>">vs. mês anterior</span>
    </div>
  <% elsif local_assigns[:hint] %>
    <div class="text-xs mt-1 <%= highlight ? "text-white/40" : "text-mist" %>"><%= local_assigns[:hint] %></div>
  <% end %>
</div>
