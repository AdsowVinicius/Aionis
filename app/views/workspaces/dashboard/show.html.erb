<% content_for :title, "#{@workspace.name} — Dashboard" %>
<% content_for :page_title, "Dashboard" %>

<% if @dashboard.empty? %>
  <%= render "empty_state" %>
<% else %>
  <% k = @dashboard.kpis %>
  <% evolution = @dashboard.monthly_evolution %>
  <div class="space-y-6">

    <%# ── KPIs (Figma Kpi ×4) — valores e deltas REAIS ──────────────────────── %>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
      <%= render "kpi_card", label: "Saldo acumulado", value: format_brl(k.general_balance_cents),
            hint: "todas as receitas − despesas",
            icon_path: "M21 12a2.25 2.25 0 00-2.25-2.25H15a3 3 0 11-6 0H5.25A2.25 2.25 0 003 12m18 0v6a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 18v-6m18 0V9M3 12V9m18 0a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 9m18 0V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v3" %>
      <%= render "kpi_card", label: "Receitas do mês", value: format_brl(k.income_cents),
            delta: mom_delta(evolution, :income_cents),
            icon_path: "M4.5 19.5l15-15m0 0H8.25m11.25 0v11.25" %>
      <%= render "kpi_card", label: "Despesas do mês", value: format_brl(k.expense_cents),
            delta: mom_delta(evolution, :expense_cents),
            icon_path: "M4.5 4.5l15 15m0 0V8.25m0 11.25H8.25" %>
      <%= render "kpi_card", label: "Saldo do mês", value: format_brl(k.balance_cents), highlight: true,
            delta: mom_delta(evolution, :balance_cents),
            icon_path: "M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" %>
    </div>

    <%# ── Mini cards (Figma MiniCard ×4) — contadores REAIS ─────────────────── %>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
      <%= render "mini_card", label: "Contas a pagar", value: format_brl(k.upcoming_payables_cents),
            sub: "vencem nos próximos 7 dias", color: "text-ink",
            icon_path: "M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5z" %>
      <%= render "mini_card", label: "Contas vencidas", value: k.overdue_payables_count,
            sub: k.overdue_payables_count == 1 ? "conta atrasada" : "contas atrasadas", color: "text-rose",
            icon_path: "M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" %>
      <%= render "mini_card", label: "Documentos pendentes", value: k.pending_docs + k.review_docs,
            sub: "aguardando revisão", color: "text-amber",
            icon_path: "M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" %>
      <% health = @dashboard.health %>
      <%= render "mini_card", label: "Saúde financeira", value: "#{health.score}/100",
            sub: health_band(health.band)[:label].downcase, color: "text-teal",
            icon_path: "M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z" %>
    </div>

    <%# ── Gráficos linha 1: fluxo de caixa + donut de categorias ────────────── %>
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <%= render layout: "chart_card", locals: { title: "Fluxo de caixa", subtitle: "últimos 6 meses", css: "lg:col-span-2" } do %>
        <%= render "cashflow_chart", flow: @dashboard.cash_flow %>
      <% end %>
      <%= render layout: "chart_card", locals: { title: "Despesas por categoria", subtitle: "mês atual" } do %>
        <%= render "donut_categories", rows: @dashboard.top_categories %>
      <% end %>
    </div>

    <%# ── Gráficos linha 2: receitas × despesas + top fornecedores ──────────── %>
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <%= render layout: "chart_card", locals: { title: "Receitas × Despesas", subtitle: "últimos 6 meses", css: "lg:col-span-2" } do %>
        <%= render "bars_evolution", rows: evolution %>
      <% end %>
      <%= render layout: "chart_card", locals: { title: "Top fornecedores", subtitle: "mês atual" } do %>
        <%= render "top_suppliers", rows: @dashboard.top_counterparties %>
      <% end %>
    </div>

    <%# ── Alertas inteligentes (insights REAIS do InsightGenerator) ─────────── %>
    <% if @dashboard.insights.any? %>
      <div>
        <div class="flex items-center justify-between mb-4">
          <h2 class="font-display">Alertas inteligentes</h2>
          <%= link_to workspace_alerts_path(@workspace), class: "text-sm text-teal flex items-center gap-1 hover:underline" do %>
            Ver todos
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" /></svg>
          <% end %>
        </div>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
          <% @dashboard.insights.first(4).each do |insight| %>
            <%= render "insight_alert", insight: insight %>
          <% end %>
        </div>
      </div>
    <% end %>

  </div>
<% end %>
