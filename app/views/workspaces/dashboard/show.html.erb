<% content_for :title, "#{@workspace.name} — Dashboard" %>
<% content_for :page_title, "Dashboard" %>

<% if @dashboard.empty? %>
  <%= render "empty_state" %>
<% else %>
  <% k = @dashboard.kpis %>
  <div class="space-y-4 md:space-y-5 max-w-6xl">

    <%# ── Hero: Health Score + KPIs ─────────────────────────────────────────── %>
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
      <%= render "health_score", health: @dashboard.health %>

      <div class="lg:col-span-2 grid grid-cols-2 gap-4">
        <%= render "metric_card", label: "Receita do mês", accent: "text-teal-700",
              value: format_brl(k.income_cents), hint: Date.current.strftime("%B/%Y").capitalize %>
        <%= render "metric_card", label: "Despesa do mês", accent: "text-red-600",
              value: format_brl(k.expense_cents), hint: Date.current.strftime("%B/%Y").capitalize %>
        <%= render "metric_card", label: "Saldo do mês",
              accent: (k.balance_cents.negative? ? "text-red-600" : "text-slate-800"),
              value: format_brl(k.balance_cents),
              hint: "Poupança: #{k.savings_rate}%" %>
        <% b = @dashboard.burn_rate %>
        <%= render "metric_card", label: "Burn rate", accent: "text-slate-800",
              value: (b.positive_cashflow ? "—" : format_brl(b.monthly_burn_cents)),
              hint: (b.runway_months ? "≈ #{b.runway_months} meses de fôlego" : (b.positive_cashflow ? "fluxo de caixa positivo" : "consumo #{burn_trend_label(b.trend)}")) %>
      </div>
    </div>

    <%# ── Receitas × Despesas (12 meses) ────────────────────────────────────── %>
    <div class="bg-white rounded-xl border border-slate-200 p-5">
      <div class="flex items-center justify-between mb-4">
        <h3 class="text-sm font-semibold text-slate-700">Receitas × Despesas</h3>
        <span class="text-xs text-slate-400">últimos 12 meses</span>
      </div>
      <%= render "bars_12m", series: @dashboard.monthly_evolution %>
    </div>

    <%# ── Fluxo de caixa + Distribuição por categorias ──────────────────────── %>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
      <div class="bg-white rounded-xl border border-slate-200 p-5">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-sm font-semibold text-slate-700">Fluxo de caixa</h3>
          <span class="text-xs text-slate-400">acumulado</span>
        </div>
        <%= render "line_chart", points: @dashboard.cash_flow %>
      </div>
      <div class="bg-white rounded-xl border border-slate-200 p-5">
        <h3 class="text-sm font-semibold text-slate-700 mb-4">Distribuição por categorias</h3>
        <%= render "ranking", rows: @dashboard.top_categories %>
      </div>
    </div>

    <%# ── Essencialidade + Top fornecedores + Top centros de custo ──────────── %>
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4">
      <div class="bg-white rounded-xl border border-slate-200 p-5">
        <h3 class="text-sm font-semibold text-slate-700 mb-4">Essenciais × Supérfluos</h3>
        <% e = @dashboard.essentiality %>
        <% if e.total_cents.zero? %>
          <p class="text-sm text-slate-400 py-6 text-center">Classifique despesas para ver a distribuição.</p>
        <% else %>
          <div class="h-3 rounded-full overflow-hidden flex bg-slate-100 mb-4">
            <% e.by_essentiality.each do |key, cents| %>
              <% next if cents.to_i.zero? %>
              <div class="<%= essentiality_color(key) %> h-full" style="width: <%= bar_width(cents, e.total_cents) %>"
                   title="<%= essentiality_label(key) %>: <%= format_brl(cents) %>"></div>
            <% end %>
          </div>
          <div class="space-y-2 text-sm">
            <div class="flex items-center justify-between">
              <span class="flex items-center gap-2 text-slate-600"><span class="w-2.5 h-2.5 rounded-sm bg-teal-500"></span>Essenciais</span>
              <span class="font-medium text-slate-700"><%= e.essential_ratio %>%</span>
            </div>
            <div class="flex items-center justify-between">
              <span class="flex items-center gap-2 text-slate-600"><span class="w-2.5 h-2.5 rounded-sm bg-red-500"></span>Supérfluos / não essenciais</span>
              <span class="font-medium text-slate-700"><%= e.superfluous_ratio %>%</span>
            </div>
          </div>
        <% end %>
      </div>

      <div class="bg-white rounded-xl border border-slate-200 p-5">
        <h3 class="text-sm font-semibold text-slate-700 mb-4">Top fornecedores</h3>
        <%= render "ranking", rows: @dashboard.top_counterparties %>
      </div>

      <div class="bg-white rounded-xl border border-slate-200 p-5">
        <h3 class="text-sm font-semibold text-slate-700 mb-4">Top centros de custo</h3>
        <%= render "ranking", rows: @dashboard.top_cost_centers %>
      </div>
    </div>

    <%# ── Insights ──────────────────────────────────────────────────────────── %>
    <% if @dashboard.insights.any? %>
      <div>
        <h3 class="text-sm font-semibold text-slate-700 mb-3 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-teal-600" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
          </svg>
          Insights
        </h3>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
          <% @dashboard.insights.each do |ins| %>
            <% s = insight_severity(ins[:severity]) %>
            <div class="border rounded-xl p-4 <%= s[:ring] %>">
              <div class="flex items-start gap-2">
                <span class="w-2 h-2 rounded-full <%= s[:dot] %> mt-1.5 shrink-0"></span>
                <div class="min-w-0">
                  <p class="text-sm font-semibold <%= s[:text] %>"><%= ins[:title] %></p>
                  <p class="text-xs text-slate-500 mt-0.5"><%= ins[:message] %></p>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>

    <%# ── Atenção / contas a vencer  ·  Documentos / mensagens ──────────────── %>
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">

      <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
        <div class="px-5 py-3 border-b border-slate-100"><h3 class="text-sm font-semibold text-slate-700">Atenção & contas a vencer</h3></div>
        <div class="divide-y divide-slate-100">
          <% if k.overdue_payables_count.positive? %>
            <div class="px-5 py-3 flex items-center justify-between">
              <span class="flex items-center gap-2 text-sm text-slate-700"><span class="w-2 h-2 rounded-full bg-red-500"></span>Contas a pagar vencidas</span>
              <%= link_to "#{k.overdue_payables_count} →", workspace_payables_path(@workspace, filter: "overdue"), class: "text-xs font-semibold text-red-600 hover:underline" %>
            </div>
          <% end %>
          <% @dashboard.upcoming_payables.each do |t| %>
            <div class="px-5 py-3 flex items-center justify-between gap-2">
              <div class="min-w-0">
                <p class="text-sm text-slate-700 truncate"><%= t.description %></p>
                <p class="text-xs text-slate-400">vence <%= t.due_on&.strftime("%d/%m") %></p>
              </div>
              <span class="text-sm font-medium text-slate-600 shrink-0"><%= format_brl(t.amount_cents) %></span>
            </div>
          <% end %>
          <% if k.overdue_payables_count.zero? && @dashboard.upcoming_payables.empty? %>
            <div class="px-5 py-4 text-center"><p class="text-xs text-slate-400">Nenhuma conta a vencer nos próximos dias.</p></div>
          <% end %>
        </div>
      </div>

      <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
        <div class="px-5 py-3 border-b border-slate-100 flex items-center justify-between">
          <h3 class="text-sm font-semibold text-slate-700">Entradas recentes</h3>
          <%= link_to "Documentos →", workspace_documents_path(@workspace), class: "text-xs text-teal-600 hover:underline" %>
        </div>
        <div class="divide-y divide-slate-100">
          <% @dashboard.recent_documents.each do |doc| %>
            <div class="px-5 py-2.5 flex items-center justify-between gap-2">
              <div class="flex items-center gap-2 min-w-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-300 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" /></svg>
                <span class="text-sm text-slate-700 truncate"><%= doc.file.attached? ? doc.file.filename.to_s : "Documento ##{doc.id}" %></span>
              </div>
              <%= document_status_badge(doc.status) %>
            </div>
          <% end %>
          <% @dashboard.recent_messages.each do |msg| %>
            <div class="px-5 py-2.5 flex items-center justify-between gap-2">
              <div class="flex items-center gap-2 min-w-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-teal-300 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M8.625 9.75a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" /></svg>
                <span class="text-sm text-slate-700 truncate">WhatsApp · <%= msg.push_name.presence || msg.from_number %></span>
              </div>
              <span class="text-xs text-slate-400 shrink-0"><%= msg.received_at&.strftime("%d/%m %H:%M") %></span>
            </div>
          <% end %>
          <% if @dashboard.recent_documents.empty? && @dashboard.recent_messages.empty? %>
            <div class="px-5 py-4 text-center"><p class="text-xs text-slate-400">Nenhum documento ou mensagem ainda.</p></div>
          <% end %>
        </div>
      </div>
    </div>

  </div>
<% end %>
