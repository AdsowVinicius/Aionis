<% content_for :title, "#{@workspace.name} — Dashboard" %>
<% content_for :page_title, "Dashboard" %>

<%# ── Cards principais ──────────────────────────────────────────────────────── %>
<div class="grid grid-cols-2 lg:grid-cols-4 gap-3 md:gap-4 mb-4 md:mb-5">

  <%# Receita do mês %>
  <div class="bg-white rounded-xl border border-slate-200 p-5">
    <div class="flex items-center justify-between mb-3">
      <span class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Receita do mês</span>
      <span class="w-7 h-7 rounded-lg bg-teal-50 flex items-center justify-center shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-teal-600" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 19.5v-15m0 0l6.75 6.75M12 4.5l-6.75 6.75" />
        </svg>
      </span>
    </div>
    <p class="text-2xl font-bold text-teal-700"><%= format_brl(@income_cents) %></p>
    <p class="text-xs text-slate-400 mt-1"><%= Date.current.strftime("%B/%Y").capitalize %></p>
  </div>

  <%# Despesa do mês %>
  <div class="bg-white rounded-xl border border-slate-200 p-5">
    <div class="flex items-center justify-between mb-3">
      <span class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Despesa do mês</span>
      <span class="w-7 h-7 rounded-lg bg-red-50 flex items-center justify-center shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-red-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m0 0l-6.75-6.75M12 19.5l6.75-6.75" />
        </svg>
      </span>
    </div>
    <p class="text-2xl font-bold text-red-600"><%= format_brl(@expense_cents) %></p>
    <p class="text-xs text-slate-400 mt-1"><%= Date.current.strftime("%B/%Y").capitalize %></p>
  </div>

  <%# Saldo do mês %>
  <div class="bg-white rounded-xl border border-slate-200 p-5">
    <div class="flex items-center justify-between mb-3">
      <span class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Saldo do mês</span>
      <span class="w-7 h-7 rounded-lg bg-slate-100 flex items-center justify-center shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </span>
    </div>
    <p class="text-2xl font-bold <%= @balance_cents >= 0 ? 'text-teal-700' : 'text-red-600' %>">
      <%= format_brl(@balance_cents) %>
    </p>
    <p class="text-xs text-slate-400 mt-1">Receitas − Despesas</p>
  </div>

  <%# Saldo geral %>
  <div class="bg-white rounded-xl border border-slate-200 p-5">
    <div class="flex items-center justify-between mb-3">
      <span class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Saldo geral</span>
      <span class="w-7 h-7 rounded-lg bg-slate-100 flex items-center justify-center shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" />
        </svg>
      </span>
    </div>
    <p class="text-2xl font-bold <%= @general_balance_cents >= 0 ? 'text-teal-700' : 'text-red-600' %>">
      <%= format_brl(@general_balance_cents) %>
    </p>
    <p class="text-xs text-slate-400 mt-1">Acumulado histórico</p>
  </div>

</div>

<%# ── Cards operacionais ────────────────────────────────────────────────────── %>
<div class="grid grid-cols-2 lg:grid-cols-4 gap-3 md:gap-4 mb-4 md:mb-5">

  <div class="bg-white rounded-xl border border-slate-200 p-4">
    <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">Lançamentos pendentes</p>
    <p class="text-xl font-bold <%= @pending_transactions_count > 0 ? 'text-amber-600' : 'text-slate-900' %>">
      <%= @pending_transactions_count %>
    </p>
    <p class="text-xs text-slate-400 mt-0.5">
      <%= link_to "Ver lançamentos →",
            workspace_financial_transactions_path(@workspace, status: "pending"),
            class: "text-teal-600 hover:underline" %>
    </p>
  </div>

  <div class="bg-white rounded-xl border border-slate-200 p-4">
    <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">Docs. pendentes</p>
    <p class="text-xl font-bold <%= @pending_docs > 0 ? 'text-amber-600' : 'text-slate-900' %>">
      <%= @pending_docs %>
    </p>
    <p class="text-xs text-slate-400 mt-0.5">
      <%= link_to "Ver documentos →",
            workspace_documents_path(@workspace),
            class: "text-teal-600 hover:underline" %>
    </p>
  </div>

  <div class="bg-white rounded-xl border border-slate-200 p-4">
    <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">Docs. em revisão</p>
    <p class="text-xl font-bold <%= @review_docs > 0 ? 'text-indigo-600' : 'text-slate-900' %>">
      <%= @review_docs %>
    </p>
    <p class="text-xs text-slate-400 mt-0.5">Aguardando revisão manual</p>
  </div>

  <div class="bg-white rounded-xl border border-slate-200 p-4">
    <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1">Fornecedores/Clientes</p>
    <p class="text-xl font-bold text-slate-900"><%= @counterparties_count %></p>
    <p class="text-xs text-slate-400 mt-0.5">
      <%= link_to "Gerenciar →",
            workspace_counterparties_path(@workspace),
            class: "text-teal-600 hover:underline" %>
    </p>
  </div>

</div>

<%# ── Seções analíticas + Últimos lançamentos ───────────────────────────────── %>
<div class="grid grid-cols-1 lg:grid-cols-2 gap-4 md:gap-5 mb-4 md:mb-5">

  <%# Top categorias de despesa do mês %>
  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <div class="px-5 py-4 border-b border-slate-100 flex items-center justify-between">
      <h3 class="text-sm font-semibold text-slate-800">Top categorias de despesa</h3>
      <span class="text-xs text-slate-400"><%= Date.current.strftime("%B/%Y").capitalize %></span>
    </div>
    <% if @top_categories.empty? %>
      <div class="px-5 py-6 text-center">
        <p class="text-sm text-slate-400">Nenhuma despesa com categoria no mês.</p>
      </div>
    <% else %>
      <%
        max_cat = @top_categories.first[:total_cents]
      %>
      <ul class="divide-y divide-slate-100">
        <% @top_categories.each do |cat| %>
          <li class="px-5 py-3">
            <div class="flex items-center justify-between mb-1">
              <span class="text-sm font-medium text-slate-700 truncate"><%= cat[:name] %></span>
              <span class="text-sm font-semibold text-red-600 shrink-0 ml-2">
                <%= format_brl(cat[:total_cents]) %>
              </span>
            </div>
            <div class="flex items-center gap-2">
              <div class="flex-1 bg-slate-100 rounded-full h-1.5">
                <div class="bg-red-400 h-1.5 rounded-full"
                     style="width: <%= max_cat > 0 ? (cat[:total_cents] * 100 / max_cat).round : 0 %>%"></div>
              </div>
              <span class="text-xs text-slate-400 shrink-0">
                <%= cat[:count] %> <%= cat[:count] == 1 ? "lançamento" : "lançamentos" %>
              </span>
            </div>
          </li>
        <% end %>
      </ul>
    <% end %>
  </div>

  <%# Top fornecedores/clientes do mês %>
  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <div class="px-5 py-4 border-b border-slate-100 flex items-center justify-between">
      <h3 class="text-sm font-semibold text-slate-800">Top fornecedores/clientes</h3>
      <span class="text-xs text-slate-400"><%= Date.current.strftime("%B/%Y").capitalize %></span>
    </div>
    <% if @top_counterparties.empty? %>
      <div class="px-5 py-6 text-center">
        <p class="text-sm text-slate-400">Nenhum lançamento com fornecedor/cliente no mês.</p>
      </div>
    <% else %>
      <%
        max_cp = @top_counterparties.first[:total_cents]
      %>
      <ul class="divide-y divide-slate-100">
        <% @top_counterparties.each do |cp| %>
          <li class="px-5 py-3">
            <div class="flex items-center justify-between mb-1">
              <span class="text-sm font-medium text-slate-700 truncate"><%= cp[:name] %></span>
              <span class="text-sm font-semibold text-slate-700 shrink-0 ml-2">
                <%= format_brl(cp[:total_cents]) %>
              </span>
            </div>
            <div class="flex items-center gap-2">
              <div class="flex-1 bg-slate-100 rounded-full h-1.5">
                <div class="bg-teal-400 h-1.5 rounded-full"
                     style="width: <%= max_cp > 0 ? (cp[:total_cents] * 100 / max_cp).round : 0 %>%"></div>
              </div>
              <span class="text-xs text-slate-400 shrink-0">
                <%= cp[:count] %> <%= cp[:count] == 1 ? "lançamento" : "lançamentos" %>
              </span>
            </div>
          </li>
        <% end %>
      </ul>
    <% end %>
  </div>

</div>

<%# ── Últimos lançamentos ─────────────────────────────────────────────────── %>
<div class="bg-white rounded-xl border border-slate-200 overflow-hidden mb-5">
  <div class="px-5 py-4 border-b border-slate-100 flex items-center justify-between">
    <h3 class="text-sm font-semibold text-slate-800">Últimos lançamentos</h3>
    <%= link_to "Ver todos →",
          workspace_financial_transactions_path(@workspace),
          class: "text-xs text-teal-600 hover:text-teal-700" %>
  </div>

  <% if @recent_transactions.empty? %>
    <div class="px-5 py-8 text-center">
      <p class="text-sm text-slate-400 mb-3">Você ainda não possui lançamentos.</p>
      <%= link_to "Criar primeiro lançamento",
            new_workspace_financial_transaction_path(@workspace),
            class: "inline-flex items-center gap-2 px-4 py-2 bg-teal-600 text-white text-sm font-semibold rounded-lg hover:bg-teal-700 transition-colors" %>
    </div>
  <% else %>
    <div class="divide-y divide-slate-100">
      <% @recent_transactions.each do |t| %>
        <div class="px-4 md:px-5 py-3 flex items-center gap-3">
          <div class="hidden sm:block shrink-0 text-xs text-slate-400 w-16 md:w-20">
            <%= (t.transacted_on || t.created_at.to_date).strftime("%d/%m/%Y") %>
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-sm font-medium text-slate-800 truncate"><%= t.description %></p>
            <p class="text-xs text-slate-400 mt-0.5 truncate">
              <% hint_parts = [t.category&.name, t.counterparty&.name].compact %>
              <span class="sm:hidden"><%= (t.transacted_on || t.created_at.to_date).strftime("%d/%m") %><%= hint_parts.any? ? " · " + hint_parts.join(" · ") : "" %></span>
              <span class="hidden sm:inline"><%= hint_parts.join(" · ").presence || "Sem categoria/fornecedor" %></span>
            </p>
          </div>
          <div class="shrink-0">
            <%= transaction_status_badge(t.status) %>
          </div>
          <div class="shrink-0 text-sm font-semibold text-right w-20 md:w-28 <%= t.income? ? 'text-teal-700' : 'text-red-600' %>">
            <%= t.income? ? "+" : "−" %><%= format_brl(t.amount_cents) %>
          </div>
          <%= link_to workspace_financial_transaction_path(@workspace, t),
                class: "hidden sm:block shrink-0 text-xs text-slate-400 hover:text-teal-600 transition-colors" do %>
            Ver →
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>

<%# ── Resumo por status + Pendências ─────────────────────────────────────── %>
<div class="grid grid-cols-1 lg:grid-cols-2 gap-5">

  <%# Resumo por status %>
  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <div class="px-5 py-4 border-b border-slate-100">
      <h3 class="text-sm font-semibold text-slate-800">Lançamentos por status</h3>
    </div>
    <% if @status_summary.empty? %>
      <div class="px-5 py-6 text-center">
        <p class="text-sm text-slate-400">Nenhum lançamento registrado.</p>
      </div>
    <% else %>
      <ul class="divide-y divide-slate-100">
        <%
          status_config = {
            "pending"    => { label: "Pendente",     color: "text-amber-600",  bg: "bg-amber-50  border border-amber-200"  },
            "classified" => { label: "Classificado", color: "text-blue-600",   bg: "bg-blue-50   border border-blue-200"   },
            "confirmed"  => { label: "Confirmado",   color: "text-teal-600",   bg: "bg-teal-50   border border-teal-200"   },
            "cancelled"  => { label: "Cancelado",    color: "text-slate-500",  bg: "bg-slate-100 border border-slate-200"  }
          }
        %>
        <% status_config.each do |status, cfg| %>
          <% count = @status_summary[status] || 0 %>
          <li class="px-5 py-3 flex items-center justify-between">
            <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium <%= cfg[:bg] %> <%= cfg[:color] %>">
              <%= cfg[:label] %>
            </span>
            <span class="text-sm font-semibold text-slate-700"><%= count %></span>
          </li>
        <% end %>
      </ul>
    <% end %>
  </div>

  <%# Pendências / Ações rápidas %>
  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <div class="px-5 py-4 border-b border-slate-100">
      <h3 class="text-sm font-semibold text-slate-800">Pendências</h3>
    </div>
    <div class="divide-y divide-slate-100">
      <%# Lançamentos pendentes %>
      <div class="px-5 py-3 flex items-center justify-between">
        <div class="flex items-center gap-2">
          <% if @pending_transactions_count > 0 %>
            <span class="w-2 h-2 rounded-full bg-amber-400 shrink-0"></span>
          <% else %>
            <span class="w-2 h-2 rounded-full bg-slate-300 shrink-0"></span>
          <% end %>
          <span class="text-sm text-slate-700">Lançamentos pendentes</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="text-sm font-semibold <%= @pending_transactions_count > 0 ? 'text-amber-600' : 'text-slate-400' %>">
            <%= @pending_transactions_count %>
          </span>
          <% if @pending_transactions_count > 0 %>
            <%= link_to "Ver →",
                  workspace_financial_transactions_path(@workspace, status: "pending"),
                  class: "text-xs text-teal-600 hover:underline" %>
          <% end %>
        </div>
      </div>

      <%# Documentos pendentes %>
      <div class="px-5 py-3 flex items-center justify-between">
        <div class="flex items-center gap-2">
          <% if @pending_docs > 0 %>
            <span class="w-2 h-2 rounded-full bg-amber-400 shrink-0"></span>
          <% else %>
            <span class="w-2 h-2 rounded-full bg-slate-300 shrink-0"></span>
          <% end %>
          <span class="text-sm text-slate-700">Documentos pendentes</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="text-sm font-semibold <%= @pending_docs > 0 ? 'text-amber-600' : 'text-slate-400' %>">
            <%= @pending_docs %>
          </span>
          <% if @pending_docs > 0 %>
            <%= link_to "Ver →",
                  workspace_documents_path(@workspace),
                  class: "text-xs text-teal-600 hover:underline" %>
          <% end %>
        </div>
      </div>

      <%# Documentos em revisão %>
      <div class="px-5 py-3 flex items-center justify-between">
        <div class="flex items-center gap-2">
          <% if @review_docs > 0 %>
            <span class="w-2 h-2 rounded-full bg-indigo-400 shrink-0"></span>
          <% else %>
            <span class="w-2 h-2 rounded-full bg-slate-300 shrink-0"></span>
          <% end %>
          <span class="text-sm text-slate-700">Documentos em revisão</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="text-sm font-semibold <%= @review_docs > 0 ? 'text-indigo-600' : 'text-slate-400' %>">
            <%= @review_docs %>
          </span>
          <% if @review_docs > 0 %>
            <%= link_to "Ver →",
                  workspace_documents_path(@workspace),
                  class: "text-xs text-teal-600 hover:underline" %>
          <% end %>
        </div>
      </div>

      <%# CTA se tudo zerado %>
      <% if @pending_transactions_count.zero? && @pending_docs.zero? && @review_docs.zero? %>
        <div class="px-5 py-4 text-center">
          <p class="text-xs text-slate-400">Nenhuma pendência. Tudo em dia.</p>
        </div>
      <% end %>
    </div>
  </div>

</div>
