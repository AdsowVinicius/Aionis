<% content_for :title, "#{@workspace.name} — Dashboard" %>
<% content_for :page_title, "Dashboard" %>

<%# Cards de métricas %>
<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-8">
  <%# Receitas do mês %>
  <div class="bg-white rounded-xl border border-slate-200 p-5">
    <div class="flex items-center justify-between mb-3">
      <span class="text-sm font-medium text-slate-500">Receitas do mês</span>
      <span class="w-8 h-8 rounded-lg bg-teal-50 flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-teal-600">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 19.5v-15m0 0l6.75 6.75M12 4.5l-6.75 6.75" />
        </svg>
      </span>
    </div>
    <p class="text-2xl font-bold text-slate-900"><%= format_brl(@income_cents) %></p>
    <p class="text-xs text-slate-400 mt-1"><%= Date.current.strftime("%B de %Y").capitalize %></p>
  </div>

  <%# Despesas do mês %>
  <div class="bg-white rounded-xl border border-slate-200 p-5">
    <div class="flex items-center justify-between mb-3">
      <span class="text-sm font-medium text-slate-500">Despesas do mês</span>
      <span class="w-8 h-8 rounded-lg bg-red-50 flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-red-500">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m0 0l-6.75-6.75M12 19.5l6.75-6.75" />
        </svg>
      </span>
    </div>
    <p class="text-2xl font-bold text-slate-900"><%= format_brl(@expense_cents) %></p>
    <p class="text-xs text-slate-400 mt-1"><%= Date.current.strftime("%B de %Y").capitalize %></p>
  </div>

  <%# Saldo %>
  <div class="bg-white rounded-xl border border-slate-200 p-5">
    <div class="flex items-center justify-between mb-3">
      <span class="text-sm font-medium text-slate-500">Saldo estimado</span>
      <span class="w-8 h-8 rounded-lg bg-slate-100 flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-slate-600">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
      </span>
    </div>
    <p class="text-2xl font-bold <%= @balance_cents >= 0 ? 'text-teal-700' : 'text-red-600' %>">
      <%= format_brl(@balance_cents) %>
    </p>
    <p class="text-xs text-slate-400 mt-1">Receitas − Despesas no mês</p>
  </div>

  <%# Lançamentos %>
  <div class="bg-white rounded-xl border border-slate-200 p-5">
    <div class="flex items-center justify-between mb-3">
      <span class="text-sm font-medium text-slate-500">Lançamentos</span>
      <span class="w-8 h-8 rounded-lg bg-slate-100 flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-slate-500">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 12h16.5m-16.5 3.75h16.5M3.75 19.5h16.5M5.625 4.5h12.75a1.875 1.875 0 010 3.75H5.625a1.875 1.875 0 010-3.75z" />
        </svg>
      </span>
    </div>
    <p class="text-2xl font-bold text-slate-900"><%= @transactions_count %></p>
    <p class="text-xs text-slate-400 mt-1">Total registrado</p>
  </div>

  <%# Documentos pendentes %>
  <div class="bg-white rounded-xl border border-slate-200 p-5">
    <div class="flex items-center justify-between mb-3">
      <span class="text-sm font-medium text-slate-500">Documentos pendentes</span>
      <span class="w-8 h-8 rounded-lg bg-blue-50 flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-blue-500">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
        </svg>
      </span>
    </div>
    <p class="text-2xl font-bold text-slate-900"><%= @pending_docs %></p>
    <p class="text-xs text-slate-400 mt-1">Aguardando processamento</p>
  </div>

  <%# Saúde financeira %>
  <% health_label, health_color = if @transactions_count.zero?
       ["Sem dados", "text-slate-400"]
     elsif @balance_cents >= 0
       ["Saudável", "text-teal-600"]
     else
       ["Atenção", "text-amber-600"]
     end %>
  <div class="bg-white rounded-xl border border-slate-200 p-5">
    <div class="flex items-center justify-between mb-3">
      <span class="text-sm font-medium text-slate-500">Saúde financeira</span>
      <span class="w-8 h-8 rounded-lg bg-purple-50 flex items-center justify-center">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-purple-500">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.746 3.746 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z" />
        </svg>
      </span>
    </div>
    <p class="text-2xl font-bold <%= health_color %>"><%= health_label %></p>
    <p class="text-xs text-slate-400 mt-1">Baseado no saldo do mês</p>
  </div>
</div>

<%# Alertas / Últimos lançamentos %>
<% if @recent_transactions.empty? %>
  <div class="bg-white rounded-xl border border-slate-200 p-6">
    <h3 class="text-base font-semibold text-slate-800 mb-4 flex items-center gap-2">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-amber-500">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
      </svg>
      Para começar
    </h3>
    <div class="space-y-3">
      <div class="flex items-start gap-3 p-3 bg-amber-50 rounded-lg border border-amber-100">
        <span class="text-amber-500 text-sm mt-0.5">●</span>
        <p class="text-sm text-slate-700">
          Você ainda não possui lançamentos.
          <%= link_to "Criar primeiro lançamento →", new_workspace_financial_transaction_path(@workspace), class: "text-teal-600 font-medium hover:underline" %>
        </p>
      </div>
      <div class="flex items-start gap-3 p-3 bg-blue-50 rounded-lg border border-blue-100">
        <span class="text-blue-400 text-sm mt-0.5">●</span>
        <p class="text-sm text-slate-700">
          Envie seu primeiro documento para o Aionis organizar seu financeiro.
          <%= link_to "Enviar documento →", workspace_documents_path(@workspace), class: "text-teal-600 font-medium hover:underline" %>
        </p>
      </div>
    </div>
  </div>
<% else %>
  <div class="bg-white rounded-xl border border-slate-200 p-6">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-base font-semibold text-slate-800">Últimos lançamentos</h3>
      <%= link_to "Ver todos →", workspace_financial_transactions_path(@workspace),
            class: "text-sm text-teal-600 hover:text-teal-700" %>
    </div>
    <div class="space-y-1">
      <% @recent_transactions.each do |t| %>
        <div class="flex items-center justify-between py-2.5 border-b border-slate-100 last:border-0">
          <div class="flex-1 min-w-0 pr-4">
            <p class="text-sm font-medium text-slate-800 truncate"><%= t.description %></p>
            <p class="text-xs text-slate-400 mt-0.5">
              <%= t.transacted_on&.strftime("%d/%m/%Y") || "—" %>
              <% if t.category %> · <%= t.category.name %><% end %>
              &nbsp;<%= transaction_status_badge(t.status) %>
            </p>
          </div>
          <span class="text-sm font-semibold whitespace-nowrap <%= t.income? ? 'text-teal-600' : 'text-red-600' %>">
            <%= t.income? ? "+" : "−" %><%= format_brl(t.amount_cents) %>
          </span>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
