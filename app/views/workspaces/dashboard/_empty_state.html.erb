<div class="bg-white rounded-2xl border border-slate-200 p-8 md:p-12 text-center max-w-2xl mx-auto mt-4">
  <div class="w-14 h-14 rounded-2xl bg-teal-50 flex items-center justify-center mx-auto mb-4">
    <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-teal-600" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" />
    </svg>
  </div>
  <h2 class="text-xl font-bold text-slate-900 mb-1">Bem-vindo ao Aionis 👋</h2>
  <p class="text-sm text-slate-500 mb-6">Registre seus primeiros lançamentos para o Aionis começar a montar sua saúde financeira, KPIs e insights.</p>
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
    <%= link_to new_workspace_financial_transaction_path(@workspace),
          class: "flex flex-col items-center gap-2 p-4 rounded-xl border border-slate-200 hover:border-teal-300 hover:bg-teal-50/50 transition-colors" do %>
      <span class="text-sm font-semibold text-slate-700">Novo lançamento</span>
      <span class="text-xs text-slate-400">Manual, em segundos</span>
    <% end %>
    <%= link_to new_workspace_document_path(@workspace),
          class: "flex flex-col items-center gap-2 p-4 rounded-xl border border-slate-200 hover:border-teal-300 hover:bg-teal-50/50 transition-colors" do %>
      <span class="text-sm font-semibold text-slate-700">Enviar documento</span>
      <span class="text-xs text-slate-400">Nota, cupom, boleto</span>
    <% end %>
    <%= link_to workspace_whatsapp_channels_path(@workspace),
          class: "flex flex-col items-center gap-2 p-4 rounded-xl border border-slate-200 hover:border-teal-300 hover:bg-teal-50/50 transition-colors" do %>
      <span class="text-sm font-semibold text-slate-700">Conectar WhatsApp</span>
      <span class="text-xs text-slate-400">Receba por mensagem</span>
    <% end %>
  </div>
</div>
