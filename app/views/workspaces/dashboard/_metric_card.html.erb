<%# locals: label, value, accent:, hint: (opcional) %>
<div class="bg-white rounded-xl border border-slate-200 p-5">
  <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide mb-2"><%= label %></p>
  <p class="text-2xl font-bold <%= accent %>"><%= value %></p>
  <% if local_assigns[:hint].present? %>
    <p class="text-xs text-slate-400 mt-1"><%= hint %></p>
  <% end %>
</div>
