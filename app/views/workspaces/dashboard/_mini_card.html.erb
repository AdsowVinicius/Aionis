<%# Card compacto (Figma MiniCard). locals: label, value, sub, icon_path, color %>
<div class="bg-white rounded-[20px] p-5 border border-border flex items-center gap-4">
  <div class="w-11 h-11 rounded-[14px] bg-cream flex items-center justify-center shrink-0 <%= color %>">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.7" stroke="currentColor" class="w-5 h-5"><path stroke-linecap="round" stroke-linejoin="round" d="<%= icon_path %>" /></svg>
  </div>
  <div class="min-w-0">
    <div class="text-xs text-mist"><%= label %></div>
    <div class="font-display text-xl truncate"><%= value %></div>
    <div class="text-xs text-mist"><%= sub %></div>
  </div>
</div>
