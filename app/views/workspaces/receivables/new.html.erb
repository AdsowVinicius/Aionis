<% content_for :title, "Nova Conta a Receber — #{current_workspace.name}" %>
<% content_for :page_title, "Nova Conta a Receber" %>

<div class="mx-auto max-w-2xl">
  <div class="flex items-center gap-3 mb-6">
    <%= link_to workspace_receivables_path(current_workspace),
          class: "text-slate-400 hover:text-slate-600 transition-colors shrink-0" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
      </svg>
    <% end %>
    <div>
      <h2 class="text-xl font-bold text-slate-900">Nova Conta a Receber</h2>
      <p class="text-slate-500 text-sm">Registre uma receita programada.</p>
    </div>
  </div>

  <div class="bg-white rounded-xl border border-slate-200 p-4 md:p-6">
    <%= render "form" %>
  </div>
</div>
