<% content_for :title, "#{@record.description} — #{current_workspace.name}" %>
<% content_for :page_title, "Conta a Receber" %>

<div class="max-w-2xl">

  <%# Cabeçalho %>
  <div class="flex items-center gap-3 mb-4 md:mb-6">
    <%= link_to workspace_receivables_path(current_workspace),
          class: "text-slate-400 hover:text-slate-600 transition-colors shrink-0" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
      </svg>
    <% end %>
    <h2 class="text-lg md:text-xl font-bold text-slate-900 truncate"><%= @record.description %></h2>
  </div>

  <%# Aviso de vencida %>
  <% if @record.overdue? %>
    <div class="bg-red-50 border border-red-200 rounded-lg px-4 py-3 mb-4 flex items-center gap-3">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5 text-red-500 shrink-0">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
      </svg>
      <p class="text-sm text-red-700">Esta conta está vencida desde <strong><%= @record.due_on.strftime("%d/%m/%Y") %></strong>.</p>
    </div>
  <% end %>

  <%# Detalhes %>
  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden mb-4">
    <div class="px-4 md:px-6 py-4 border-b border-slate-100 flex items-start sm:items-center justify-between gap-3">
      <div class="min-w-0">
        <p class="text-xl md:text-2xl font-bold text-teal-600"><%= format_brl(@record.amount_cents) %></p>
        <p class="text-sm text-slate-500 mt-0.5 truncate"><%= @record.description %></p>
      </div>
      <div class="flex flex-col items-end gap-2 shrink-0">
        <%= settlement_status_badge(@record.settlement_status) %>
        <%= transaction_status_badge(@record.status) %>
      </div>
    </div>

    <dl class="divide-y divide-slate-100">
      <div class="px-4 md:px-6 py-3 flex flex-col sm:flex-row sm:gap-4">
        <dt class="text-xs sm:text-sm text-slate-500 sm:w-44 sm:shrink-0 mb-0.5 sm:mb-0">Vencimento / Previsão</dt>
        <dd class="text-sm font-medium <%= @record.overdue? ? 'text-red-600' : 'text-slate-800' %>">
          <%= @record.due_on&.strftime("%d/%m/%Y") || "—" %>
        </dd>
      </div>
      <% if @record.settlement_settled? %>
        <div class="px-4 md:px-6 py-3 flex flex-col sm:flex-row sm:gap-4">
          <dt class="text-xs sm:text-sm text-slate-500 sm:w-44 sm:shrink-0 mb-0.5 sm:mb-0">Recebido em</dt>
          <dd class="text-sm font-medium text-teal-700"><%= @record.settled_on&.strftime("%d/%m/%Y") || "—" %></dd>
        </div>
      <% end %>
      <div class="px-4 md:px-6 py-3 flex flex-col sm:flex-row sm:gap-4">
        <dt class="text-xs sm:text-sm text-slate-500 sm:w-44 sm:shrink-0 mb-0.5 sm:mb-0">Categoria</dt>
        <dd class="text-sm font-medium text-slate-800">
          <% if @record.category %>
            <%= link_to @record.category.name,
                  workspace_category_path(current_workspace, @record.category),
                  class: "text-teal-600 hover:text-teal-700 hover:underline" %>
          <% else %>
            <span class="text-slate-400 italic">Sem categoria</span>
          <% end %>
        </dd>
      </div>
      <div class="px-4 md:px-6 py-3 flex flex-col sm:flex-row sm:gap-4">
        <dt class="text-xs sm:text-sm text-slate-500 sm:w-44 sm:shrink-0 mb-0.5 sm:mb-0">Cliente / Fornecedor</dt>
        <dd class="text-sm font-medium text-slate-800">
          <% if @record.counterparty %>
            <%= link_to @record.counterparty.name,
                  workspace_counterparty_path(current_workspace, @record.counterparty),
                  class: "text-teal-600 hover:text-teal-700 hover:underline" %>
          <% else %>
            <span class="text-slate-400 italic">Não informado</span>
          <% end %>
        </dd>
      </div>
      <div class="px-4 md:px-6 py-3 flex flex-col sm:flex-row sm:gap-4">
        <dt class="text-xs sm:text-sm text-slate-500 sm:w-44 sm:shrink-0 mb-0.5 sm:mb-0">Documento vinculado</dt>
        <dd class="text-sm font-medium text-slate-800">
          <% if @record.document %>
            <% doc_label = @record.document.file.attached? ? @record.document.file.blob.filename.to_s : "Documento ##{@record.document_id}" %>
            <%= link_to doc_label,
                  workspace_document_path(current_workspace, @record.document),
                  class: "text-teal-600 hover:text-teal-700 hover:underline" %>
          <% else %>
            <span class="text-slate-400 italic">Nenhum documento vinculado</span>
          <% end %>
        </dd>
      </div>
      <% if @record.notes.present? %>
        <div class="px-4 md:px-6 py-3 flex flex-col sm:flex-row sm:gap-4">
          <dt class="text-xs sm:text-sm text-slate-500 sm:w-44 sm:shrink-0 mb-0.5 sm:mb-0">Observações</dt>
          <dd class="text-sm text-slate-700"><%= @record.notes %></dd>
        </div>
      <% end %>
      <div class="px-4 md:px-6 py-3 flex flex-col sm:flex-row sm:gap-4">
        <dt class="text-xs sm:text-sm text-slate-500 sm:w-44 sm:shrink-0 mb-0.5 sm:mb-0">Criado em</dt>
        <dd class="text-sm text-slate-500"><%= @record.created_at.strftime("%d/%m/%Y às %H:%M") %></dd>
      </div>
    </dl>
  </div>

  <%# Ações %>
  <div class="flex flex-wrap items-center gap-2 md:gap-3">
    <% if @record.settlement_open? %>
      <%= button_to settle_workspace_receivable_path(current_workspace, @record),
            method: :patch,
            class: "inline-flex items-center gap-2 px-4 py-2 bg-teal-600 text-white text-sm font-medium rounded-lg hover:bg-teal-700 transition-colors cursor-pointer" do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        Marcar como recebido
      <% end %>
    <% end %>

    <% unless @record.settlement_cancelled? %>
      <%= link_to edit_workspace_receivable_path(current_workspace, @record),
            class: "inline-flex items-center gap-2 px-4 py-2 bg-white border border-slate-300 text-slate-700 text-sm font-medium rounded-lg hover:bg-slate-50 transition-colors" do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125" />
        </svg>
        Editar
      <% end %>
    <% end %>

    <%= button_to workspace_receivable_path(current_workspace, @record),
          method: :delete,
          form: { data: { turbo_confirm: @record.settlement_settled? ? "Esta conta já foi recebida. Deseja cancelá-la?" : "Excluir esta conta a receber?" } },
          class: "inline-flex items-center gap-2 px-4 py-2 bg-white border border-red-300 text-red-600 text-sm font-medium rounded-lg hover:bg-red-50 transition-colors cursor-pointer" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
      </svg>
      <%= @record.settlement_settled? ? "Cancelar" : "Excluir" %>
    <% end %>

    <%= link_to "← Voltar", workspace_receivables_path(current_workspace),
          class: "px-4 py-2 text-sm text-slate-500 hover:text-slate-700 transition-colors" %>
  </div>

</div>
