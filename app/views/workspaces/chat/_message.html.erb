<%# Bolha de mensagem (Figma Assistant): IA = avatar gradiente + bolha cream;
    usuário = bolha navy + avatar de iniciais. locals: role, content %>
<% user = role == "user" %>
<div class="flex gap-3 <%= "justify-end" if user %>">
  <% unless user %>
    <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-teal to-ink flex items-center justify-center text-white shrink-0">
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor" class="w-3.5 h-3.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" /></svg>
    </div>
  <% end %>
  <div class="max-w-[75%]">
    <div class="rounded-[20px] p-4 text-sm leading-relaxed whitespace-pre-wrap <%= user ? "bg-ink text-white rounded-tr-sm" : "bg-cream text-ink rounded-tl-sm" %>">
      <%= content %>
    </div>
  </div>
  <% if user %>
    <div class="w-8 h-8 rounded-lg bg-ink text-white flex items-center justify-center shrink-0 text-xs font-semibold">
      <%= user_initials(current_user) %>
    </div>
  <% end %>
</div>
