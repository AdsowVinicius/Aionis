<%= form_with model: [current_workspace, @transaction], local: true, class: "space-y-5" do |f| %>

  <%# Erros de validação %>
  <% if @transaction.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <p class="text-sm font-medium text-red-700 mb-1">
        <%= pluralize(@transaction.errors.count, "erro", "erros") %> impediram salvar este lançamento:
      </p>
      <ul class="list-disc list-inside text-sm text-red-600 space-y-0.5">
        <% @transaction.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# Sugestão automática vinda do parser fiscal de XML %>
  <% if @suggested_from_extraction %>
    <div class="bg-teal-50 border border-teal-200 rounded-lg p-4">
      <div class="flex items-start gap-3">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-teal-600 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke-width="1.8" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
        </svg>
        <div>
          <p class="text-sm font-medium text-teal-800">
            Dados preenchidos automaticamente a partir do documento fiscal.
          </p>
          <p class="text-xs text-teal-700 mt-0.5">
            <% if @suggested_confidence %>Confiança da leitura: <strong><%= @suggested_confidence %>%</strong>. <% end %>
            Confira os campos abaixo antes de salvar.
          </p>
        </div>
      </div>
    </div>
  <% end %>

  <%# Snapshots do fornecedor extraídos do documento (CPF/CNPJ opcional) %>
  <%= f.hidden_field :counterparty_name_snapshot %>
  <%= f.hidden_field :counterparty_tax_id_snapshot %>
  <%= f.hidden_field :counterparty_tax_id_status %>

  <%# Tipo %>
  <div>
    <%= f.label :kind, "Tipo *", class: "block text-sm font-medium text-slate-700 mb-2" %>
    <div class="flex gap-3">
      <label class="flex-1 flex items-center justify-center gap-2 border rounded-lg px-4 py-3 cursor-pointer text-sm font-medium transition-colors
        <%= @transaction.income? ? 'bg-teal-50 border-teal-400 text-teal-700' : 'bg-white border-slate-300 text-slate-600 hover:border-teal-300 hover:bg-teal-50/50' %>">
        <%= f.radio_button :kind, "income", class: "sr-only" %>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 19.5v-15m0 0l6.75 6.75M12 4.5l-6.75 6.75" />
        </svg>
        Receita
      </label>
      <label class="flex-1 flex items-center justify-center gap-2 border rounded-lg px-4 py-3 cursor-pointer text-sm font-medium transition-colors
        <%= @transaction.expense? ? 'bg-red-50 border-red-400 text-red-700' : 'bg-white border-slate-300 text-slate-600 hover:border-red-300 hover:bg-red-50/50' %>">
        <%= f.radio_button :kind, "expense", class: "sr-only" %>
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m0 0l-6.75-6.75M12 19.5l6.75-6.75" />
        </svg>
        Despesa
      </label>
    </div>
  </div>

  <%# Descrição %>
  <div>
    <%= f.label :description, "Descrição *", class: "block text-sm font-medium text-slate-700 mb-1" %>
    <%= f.text_field :description,
          placeholder: "Ex: Compra de material na loja do bairro",
          class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-teal-500" %>
  </div>

  <%# Valor e Data %>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <%= f.label :amount_brl, "Valor (R$) *", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <div class="relative">
        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm select-none">R$</span>
        <%= f.text_field :amount_brl,
              value: @transaction.amount_cents.to_i > 0 ? number_with_precision(@transaction.amount_brl, precision: 2, separator: ",", delimiter: ".") : nil,
              placeholder: "0,00",
              inputmode: "decimal",
              autocomplete: "off",
              class: "w-full pl-9 pr-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-teal-500" %>
      </div>
      <p class="text-xs text-slate-400 mt-1">Use vírgula para centavos. Ex: 1.200,50</p>
    </div>
    <div>
      <%= f.label :transacted_on, "Data do lançamento", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.date_field :transacted_on,
            class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-teal-500" %>
    </div>
  </div>

  <%# Status %>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <%= f.label :status, "Status", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.select :status,
            [["Pendente", "pending"], ["Classificado", "classified"], ["Confirmado", "confirmed"], ["Cancelado", "cancelled"]],
            { selected: @transaction.status || "pending" },
            class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-teal-500" %>
    </div>
  </div>

  <%# Categoria e Fornecedor/Cliente (ambos opcionais) %>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
    <div>
      <%= f.label :category_id, class: "block text-sm font-medium text-slate-700 mb-1" do %>
        Categoria <span class="text-slate-400 font-normal">(opcional)</span>
      <% end %>
      <%= f.select :category_id,
            [["— Nenhuma —", ""]] + @categories.map { |c| [c.name, c.id] },
            { selected: @transaction.category_id },
            class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-teal-500" %>
    </div>
    <div>
      <%= f.label :counterparty_id, class: "block text-sm font-medium text-slate-700 mb-1" do %>
        Fornecedor / Cliente <span class="text-slate-400 font-normal">(opcional)</span>
      <% end %>
      <%= f.select :counterparty_id,
            [["— Nenhum —", ""]] + @counterparties.map { |c| [c.name, c.id] },
            { selected: @transaction.counterparty_id },
            class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-teal-500" %>
      <p class="text-xs text-slate-400 mt-1">CPF/CNPJ não é obrigatório. Informe se souber.</p>
      <% if @transaction.counterparty_name_snapshot.present? && @transaction.counterparty_id.blank? %>
        <p class="text-xs text-amber-600 mt-1">
          Documento indica: <strong><%= @transaction.counterparty_name_snapshot %></strong><%= " (#{@transaction.counterparty_tax_id_snapshot})" if @transaction.counterparty_tax_id_snapshot.present? %>.
          Nenhum fornecedor cadastrado corresponde — selecione um acima ou salve assim mesmo.
        </p>
      <% end %>
    </div>
  </div>

  <%# Documento vinculado (opcional) %>
  <div>
    <%= f.label :document_id, class: "block text-sm font-medium text-slate-700 mb-1" do %>
      Documento vinculado <span class="text-slate-400 font-normal">(opcional)</span>
    <% end %>
    <%= f.select :document_id,
          [["— Nenhum —", ""]] + @documents.map { |d|
            label = d.file.attached? ? d.file.blob.filename.to_s : "Documento ##{d.id}"
            [label, d.id]
          },
          { selected: @transaction.document_id },
          class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-teal-500 bg-white" %>
    <p class="text-xs text-slate-400 mt-1">Vincule este lançamento a um documento já enviado, se houver.</p>
  </div>

  <%# Botões %>
  <div class="flex items-center gap-3 pt-2 border-t border-slate-100">
    <%= f.submit @transaction.new_record? ? "Criar lançamento" : "Salvar alterações",
          class: "px-5 py-2 bg-teal-600 text-white text-sm font-semibold rounded-lg hover:bg-teal-700 transition-colors cursor-pointer" %>
    <%= link_to "Cancelar", workspace_financial_transactions_path(current_workspace),
          class: "px-5 py-2 bg-slate-100 text-slate-600 text-sm font-medium rounded-lg hover:bg-slate-200 transition-colors" %>
  </div>

<% end %>
