<% content_for :title, "Lançamentos — #{current_workspace.name}" %>
<% content_for :page_title, "Lançamentos" %>

<div class="max-w-6xl">

  <%# Cabeçalho %>
  <div class="flex items-center justify-between mb-6">
    <div>
      <h2 class="text-xl font-bold text-slate-900">Lançamentos financeiros</h2>
      <p class="text-slate-500 text-sm mt-0.5">Receitas e despesas do workspace.</p>
    </div>
    <%= link_to new_workspace_financial_transaction_path(current_workspace),
          class: "inline-flex items-center gap-2 px-4 py-2 bg-teal-600 text-white text-sm font-semibold rounded-lg hover:bg-teal-700 transition-colors" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
      </svg>
      Novo lançamento
    <% end %>
  </div>

  <%# Cards de resumo %>
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
    <div class="bg-white rounded-xl border border-slate-200 p-4">
      <p class="text-xs font-medium text-slate-500 mb-1 uppercase tracking-wide">Receitas</p>
      <p class="text-xl font-bold text-teal-600"><%= format_brl(@summary_income_cents) %></p>
      <p class="text-xs text-slate-400 mt-0.5">Total acumulado</p>
    </div>
    <div class="bg-white rounded-xl border border-slate-200 p-4">
      <p class="text-xs font-medium text-slate-500 mb-1 uppercase tracking-wide">Despesas</p>
      <p class="text-xl font-bold text-red-600"><%= format_brl(@summary_expense_cents) %></p>
      <p class="text-xs text-slate-400 mt-0.5">Total acumulado</p>
    </div>
    <div class="bg-white rounded-xl border border-slate-200 p-4">
      <p class="text-xs font-medium text-slate-500 mb-1 uppercase tracking-wide">Saldo</p>
      <p class="text-xl font-bold <%= @summary_balance_cents >= 0 ? 'text-teal-700' : 'text-red-600' %>">
        <%= format_brl(@summary_balance_cents) %>
      </p>
      <p class="text-xs text-slate-400 mt-0.5">Receitas − Despesas</p>
    </div>
    <div class="bg-white rounded-xl border border-slate-200 p-4">
      <p class="text-xs font-medium text-slate-500 mb-1 uppercase tracking-wide">Lançamentos</p>
      <p class="text-xl font-bold text-slate-900"><%= @summary_count %></p>
      <p class="text-xs text-slate-400 mt-0.5">Total registrado</p>
    </div>
  </div>

  <%# Filtros %>
  <%= form_with url: workspace_financial_transactions_path(current_workspace), method: :get,
        class: "bg-white rounded-xl border border-slate-200 p-4 mb-4" do |f| %>
    <div class="flex flex-wrap gap-3 items-end">
      <div class="flex-1 min-w-[160px]">
        <%= f.label :q, "Buscar", class: "block text-xs font-medium text-slate-600 mb-1" %>
        <%= f.text_field :q, value: params[:q], placeholder: "Descrição...",
              class: "w-full text-sm border border-slate-300 rounded-lg px-3 py-1.5 focus:outline-none focus:ring-2 focus:ring-teal-500" %>
      </div>
      <div>
        <%= f.label :kind, "Tipo", class: "block text-xs font-medium text-slate-600 mb-1" %>
        <%= f.select :kind,
              [["Todos", ""], ["Receitas", "income"], ["Despesas", "expense"]],
              { selected: params[:kind] },
              class: "text-sm border border-slate-300 rounded-lg px-3 py-1.5 focus:outline-none focus:ring-2 focus:ring-teal-500" %>
      </div>
      <div>
        <%= f.label :status, "Status", class: "block text-xs font-medium text-slate-600 mb-1" %>
        <%= f.select :status,
              [["Todos", ""], ["Pendente", "pending"], ["Classificado", "classified"], ["Confirmado", "confirmed"], ["Cancelado", "cancelled"]],
              { selected: params[:status] },
              class: "text-sm border border-slate-300 rounded-lg px-3 py-1.5 focus:outline-none focus:ring-2 focus:ring-teal-500" %>
      </div>
      <% if @categories.any? %>
        <div>
          <%= f.label :category_id, "Categoria", class: "block text-xs font-medium text-slate-600 mb-1" %>
          <%= f.select :category_id,
                [["Todas", ""]] + @categories.map { |c| [c.name, c.id] },
                { selected: params[:category_id] },
                class: "text-sm border border-slate-300 rounded-lg px-3 py-1.5 focus:outline-none focus:ring-2 focus:ring-teal-500" %>
        </div>
      <% end %>
      <div>
        <%= f.label :period, "Período", class: "block text-xs font-medium text-slate-600 mb-1" %>
        <%= f.month_field :period, value: params[:period],
              class: "text-sm border border-slate-300 rounded-lg px-3 py-1.5 focus:outline-none focus:ring-2 focus:ring-teal-500" %>
      </div>
      <div class="flex gap-2">
        <%= f.submit "Filtrar",
              class: "px-4 py-1.5 bg-slate-700 text-white text-sm font-medium rounded-lg hover:bg-slate-800 transition-colors cursor-pointer" %>
        <% if [params[:q], params[:kind], params[:status], params[:category_id], params[:period]].any?(&:present?) %>
          <%= link_to "Limpar", workspace_financial_transactions_path(current_workspace),
                class: "px-4 py-1.5 bg-slate-100 text-slate-600 text-sm font-medium rounded-lg hover:bg-slate-200 transition-colors" %>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Tabela / Estado vazio %>
  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <% if @transactions.empty? %>
      <div class="p-12 text-center">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" class="w-12 h-12 text-slate-300 mx-auto mb-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" />
        </svg>
        <h3 class="text-base font-semibold text-slate-700 mb-1">Nenhum lançamento encontrado</h3>
        <p class="text-sm text-slate-500 mb-4">
          <% if [params[:q], params[:kind], params[:status], params[:category_id], params[:period]].any?(&:present?) %>
            Nenhum resultado para os filtros aplicados.
            <%= link_to "Limpar filtros", workspace_financial_transactions_path(current_workspace), class: "text-teal-600 hover:underline" %>
          <% else %>
            Você ainda não possui lançamentos. Cadastre uma receita ou despesa manual para começar.
          <% end %>
        </p>
        <%= link_to "Novo lançamento", new_workspace_financial_transaction_path(current_workspace),
              class: "inline-flex items-center gap-2 px-4 py-2 bg-teal-600 text-white text-sm font-semibold rounded-lg hover:bg-teal-700 transition-colors" %>
      </div>
    <% else %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-slate-200 bg-slate-50">
              <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider whitespace-nowrap">Data</th>
              <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Descrição</th>
              <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Tipo</th>
              <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Categoria</th>
              <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Fornecedor/Cliente</th>
              <th class="text-right px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider whitespace-nowrap">Valor</th>
              <th class="text-center px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Status</th>
              <th class="text-right px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Ações</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @transactions.each do |t| %>
              <tr class="hover:bg-slate-50/70 transition-colors">
                <td class="px-4 py-3 text-slate-500 whitespace-nowrap text-xs">
                  <%= t.transacted_on&.strftime("%d/%m/%Y") || "—" %>
                </td>
                <td class="px-4 py-3 max-w-xs">
                  <p class="font-medium text-slate-800 truncate"><%= t.description %></p>
                </td>
                <td class="px-4 py-3 whitespace-nowrap">
                  <% if t.income? %>
                    <span class="inline-flex items-center gap-1 bg-teal-50 text-teal-700 px-2 py-0.5 rounded-full text-xs font-medium border border-teal-200">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 19.5v-15m0 0l6.75 6.75M12 4.5l-6.75 6.75" />
                      </svg>
                      Receita
                    </span>
                  <% else %>
                    <span class="inline-flex items-center gap-1 bg-red-50 text-red-700 px-2 py-0.5 rounded-full text-xs font-medium border border-red-200">
                      <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m0 0l-6.75-6.75M12 19.5l6.75-6.75" />
                      </svg>
                      Despesa
                    </span>
                  <% end %>
                </td>
                <td class="px-4 py-3 text-slate-500 text-xs">
                  <%= t.category&.name || "—" %>
                </td>
                <td class="px-4 py-3 text-slate-500 text-xs">
                  <%= t.counterparty&.name || t.counterparty_name_snapshot.presence || "—" %>
                </td>
                <td class="px-4 py-3 text-right font-semibold whitespace-nowrap <%= t.income? ? 'text-teal-700' : 'text-red-600' %>">
                  <%= t.income? ? "+" : "−" %><%= format_brl(t.amount_cents) %>
                </td>
                <td class="px-4 py-3 text-center">
                  <%= transaction_status_badge(t.status) %>
                </td>
                <td class="px-4 py-3 text-right whitespace-nowrap">
                  <div class="inline-flex items-center gap-1">
                    <%= link_to workspace_financial_transaction_path(current_workspace, t),
                          class: "p-1.5 text-slate-400 hover:text-teal-600 hover:bg-teal-50 rounded-lg transition-colors",
                          title: "Ver detalhes" do %>
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.641 0-8.573-3.007-9.963-7.178z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                      </svg>
                    <% end %>
                    <%= link_to edit_workspace_financial_transaction_path(current_workspace, t),
                          class: "p-1.5 text-slate-400 hover:text-teal-600 hover:bg-teal-50 rounded-lg transition-colors",
                          title: "Editar" do %>
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
                      </svg>
                    <% end %>
                    <%= button_to workspace_financial_transaction_path(current_workspace, t),
                          method: :delete,
                          form: { data: { turbo_confirm: "Remover este lançamento? Esta ação não pode ser desfeita." } },
                          class: "p-1.5 text-slate-400 hover:text-red-500 hover:bg-red-50 rounded-lg transition-colors cursor-pointer bg-transparent border-0",
                          title: "Remover" do %>
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                      </svg>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </div>

</div>
