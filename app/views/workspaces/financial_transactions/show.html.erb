<% content_for :title, "Lançamento ##{@transaction.id} — #{current_workspace.name}" %>
<% content_for :page_title, "Detalhes do lançamento" %>

<div class="max-w-2xl">
  <div class="flex items-center gap-3 mb-6">
    <%= link_to workspace_financial_transactions_path(current_workspace),
          class: "text-slate-400 hover:text-slate-600 transition-colors" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
      </svg>
    <% end %>
    <h2 class="text-xl font-bold text-slate-900">Detalhes do lançamento</h2>
  </div>

  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden mb-4">

    <%# Cabeçalho com valor e tipo %>
    <div class="px-6 py-5 border-b border-slate-100 flex items-center justify-between">
      <div>
        <p class="text-2xl font-bold <%= @transaction.income? ? 'text-teal-700' : 'text-red-600' %>">
          <%= @transaction.income? ? "+" : "−" %><%= format_brl(@transaction.amount_cents) %>
        </p>
        <p class="text-sm text-slate-500 mt-0.5"><%= @transaction.description %></p>
      </div>
      <div class="flex flex-col items-end gap-2">
        <% if @transaction.income? %>
          <span class="inline-flex items-center gap-1 bg-teal-50 text-teal-700 border border-teal-200 px-3 py-1 rounded-full text-sm font-medium">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 19.5v-15m0 0l6.75 6.75M12 4.5l-6.75 6.75" />
            </svg>
            Receita
          </span>
        <% else %>
          <span class="inline-flex items-center gap-1 bg-red-50 text-red-700 border border-red-200 px-3 py-1 rounded-full text-sm font-medium">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m0 0l-6.75-6.75M12 19.5l6.75-6.75" />
            </svg>
            Despesa
          </span>
        <% end %>
        <%= transaction_status_badge(@transaction.status) %>
      </div>
    </div>

    <%# Detalhes %>
    <dl class="divide-y divide-slate-100">
      <div class="px-6 py-3 flex gap-4">
        <dt class="text-sm text-slate-500 w-44 shrink-0">Data do lançamento</dt>
        <dd class="text-sm font-medium text-slate-800">
          <%= @transaction.transacted_on&.strftime("%d/%m/%Y") || "—" %>
        </dd>
      </div>
      <div class="px-6 py-3 flex gap-4">
        <dt class="text-sm text-slate-500 w-44 shrink-0">Categoria</dt>
        <dd class="text-sm font-medium text-slate-800">
          <%= @transaction.category&.name || "—" %>
        </dd>
      </div>
      <div class="px-6 py-3 flex gap-4">
        <dt class="text-sm text-slate-500 w-44 shrink-0">Fornecedor / Cliente</dt>
        <dd class="text-sm font-medium text-slate-800">
          <%= @transaction.counterparty&.name || @transaction.counterparty_name_snapshot || "—" %>
        </dd>
      </div>
      <div class="px-6 py-3 flex gap-4">
        <dt class="text-sm text-slate-500 w-44 shrink-0">Origem</dt>
        <dd class="text-sm font-medium text-slate-800 capitalize">
          <%= { "manual" => "Manual", "document" => "Documento", "import" => "Importação" }[@transaction.origin] || @transaction.origin %>
        </dd>
      </div>
      <% if @transaction.document.present? %>
        <div class="px-6 py-3 flex gap-4">
          <dt class="text-sm text-slate-500 w-44 shrink-0">Documento vinculado</dt>
          <dd class="text-sm font-medium text-slate-800">
            <%= link_to "Documento ##{@transaction.document_id}", workspace_document_path(current_workspace, @transaction.document),
                  class: "text-teal-600 hover:underline" %>
          </dd>
        </div>
      <% end %>
      <div class="px-6 py-3 flex gap-4">
        <dt class="text-sm text-slate-500 w-44 shrink-0">Criado em</dt>
        <dd class="text-sm text-slate-500">
          <%= @transaction.created_at.strftime("%d/%m/%Y às %H:%M") %>
        </dd>
      </div>
      <div class="px-6 py-3 flex gap-4">
        <dt class="text-sm text-slate-500 w-44 shrink-0">Atualizado em</dt>
        <dd class="text-sm text-slate-500">
          <%= @transaction.updated_at.strftime("%d/%m/%Y às %H:%M") %>
        </dd>
      </div>
    </dl>
  </div>

  <%# Ações %>
  <div class="flex items-center gap-3">
    <%= link_to edit_workspace_financial_transaction_path(current_workspace, @transaction),
          class: "inline-flex items-center gap-2 px-4 py-2 bg-teal-600 text-white text-sm font-medium rounded-lg hover:bg-teal-700 transition-colors" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487l1.687-1.688a1.875 1.875 0 112.652 2.652L10.582 16.07a4.5 4.5 0 01-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 011.13-1.897l8.932-8.931zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0115.75 21H5.25A2.25 2.25 0 013 18.75V8.25A2.25 2.25 0 015.25 6H10" />
      </svg>
      Editar
    <% end %>

    <%= button_to workspace_financial_transaction_path(current_workspace, @transaction),
          method: :delete,
          form: { data: { turbo_confirm: "Tem certeza que deseja remover este lançamento? Esta ação não pode ser desfeita." } },
          class: "inline-flex items-center gap-2 px-4 py-2 bg-white border border-red-300 text-red-600 text-sm font-medium rounded-lg hover:bg-red-50 transition-colors cursor-pointer" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
      </svg>
      Remover
    <% end %>

    <%= link_to "← Voltar para lançamentos", workspace_financial_transactions_path(current_workspace),
          class: "px-4 py-2 text-sm text-slate-500 hover:text-slate-700 transition-colors" %>
  </div>
</div>
