<% content_for :title, "Workspaces — Aionis" %>
<% content_for :page_title, "Meus Workspaces" %>

<div class="max-w-2xl">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h2 class="text-xl font-bold text-slate-900">Workspaces</h2>
      <p class="text-slate-500 text-sm mt-0.5">Gerencie seus perfis financeiros.</p>
    </div>
    <%= link_to new_workspace_path,
          class: "flex items-center gap-2 bg-teal-600 hover:bg-teal-700 text-white text-sm font-medium px-4 py-2 rounded-lg transition-colors" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
      </svg>
      Novo workspace
    <% end %>
  </div>

  <% if @workspaces.any? %>
    <div class="space-y-3">
      <% @workspaces.each do |workspace| %>
        <div class="bg-white rounded-xl border border-slate-200 p-5 flex items-center justify-between">
          <div>
            <h3 class="font-semibold text-slate-900"><%= workspace.name %></h3>
            <p class="text-sm text-slate-500 mt-0.5 capitalize"><%= workspace.kind %></p>
          </div>
          <%= link_to workspace_dashboard_path(workspace),
                class: "text-sm text-teal-600 hover:text-teal-700 font-medium" do %>
            Acessar →
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="bg-white rounded-xl border border-dashed border-slate-300 p-10 text-center">
      <p class="text-slate-500 mb-4">Você ainda não tem workspaces.</p>
      <%= link_to "Criar primeiro workspace", new_workspace_path,
            class: "text-sm bg-teal-600 hover:bg-teal-700 text-white font-medium px-5 py-2.5 rounded-lg transition-colors" %>
    </div>
  <% end %>
</div>
