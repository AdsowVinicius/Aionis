<%= form_with model: [current_workspace, @counterparty] do |f| %>
  <% if @counterparty.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-6">
      <p class="text-sm font-medium text-red-700 mb-1">
        <%= pluralize(@counterparty.errors.count, "erro encontrado", "erros encontrados") %>:
      </p>
      <ul class="list-disc list-inside text-sm text-red-600 space-y-0.5">
        <% @counterparty.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="space-y-5">

    <%# Nome %>
    <div>
      <div class="flex items-center justify-between mb-1">
        <%= f.label :name, "Nome", class: "text-sm font-medium text-slate-700" %>
        <span class="text-xs text-red-500">Obrigatório</span>
      </div>
      <%= f.text_field :name,
            class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent",
            placeholder: "Nome do fornecedor ou cliente" %>
    </div>

    <%# Tipo %>
    <div>
      <div class="flex items-center justify-between mb-1">
        <%= f.label :kind, "Tipo", class: "text-sm font-medium text-slate-700" %>
        <span class="text-xs text-red-500">Obrigatório</span>
      </div>
      <%= f.select :kind,
            [["Fornecedor", "supplier"], ["Cliente", "client"], ["Ambos", "both"]],
            { include_blank: "Selecione o tipo" },
            class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent bg-white" %>
    </div>

    <%# CPF/CNPJ %>
    <div>
      <div class="flex items-center justify-between mb-1">
        <%= f.label :tax_id, "CPF/CNPJ", class: "text-sm font-medium text-slate-700" %>
        <span class="text-xs text-slate-400">Opcional</span>
      </div>
      <%= f.text_field :tax_id,
            class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent",
            placeholder: "000.000.000-00 ou 00.000.000/0000-00" %>
      <p class="text-xs text-slate-500 mt-1">
        CPF/CNPJ é opcional. Informe se souber. Isso ajuda o Aionis a identificar documentos e evitar duplicidade.
      </p>
    </div>

    <%# Observações %>
    <div>
      <div class="flex items-center justify-between mb-1">
        <%= f.label :notes, "Observações", class: "text-sm font-medium text-slate-700" %>
        <span class="text-xs text-slate-400">Opcional</span>
      </div>
      <%= f.text_area :notes,
            rows: 3,
            class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent resize-none",
            placeholder: "Informações adicionais sobre este fornecedor ou cliente" %>
    </div>

  </div>

  <div class="flex items-center gap-3 mt-6 pt-5 border-t border-slate-100">
    <%= f.submit(@counterparty.persisted? ? "Salvar alterações" : "Cadastrar",
          class: "px-5 py-2 bg-teal-600 text-white text-sm font-semibold rounded-lg hover:bg-teal-700 transition-colors cursor-pointer") %>
    <%= link_to "Cancelar",
          (@counterparty.persisted? ? workspace_counterparty_path(current_workspace, @counterparty) : workspace_counterparties_path(current_workspace)),
          class: "px-4 py-2 text-sm text-slate-500 hover:text-slate-700 transition-colors" %>
  </div>
<% end %>
