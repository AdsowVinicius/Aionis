<% content_for :title, "#{@counterparty.name} — #{current_workspace.name}" %>
<% content_for :page_title, "Fornecedor/cliente" %>

<div class="max-w-3xl">

  <%# Cabeçalho %>
  <div class="flex items-center gap-3 mb-6">
    <%= link_to workspace_counterparties_path(current_workspace),
          class: "text-slate-400 hover:text-slate-600 transition-colors" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
      </svg>
    <% end %>
    <h2 class="text-xl font-bold text-slate-900 truncate"><%= @counterparty.name %></h2>
  </div>

  <%# Detalhes %>
  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden mb-4">
    <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between gap-4">
      <div>
        <p class="font-semibold text-slate-900"><%= @counterparty.name %></p>
        <p class="text-xs text-slate-400 mt-0.5"><%= counterparty_kind_label(@counterparty.kind) %></p>
      </div>
      <%= tax_id_status_badge(@counterparty.tax_id_status) %>
    </div>

    <dl class="divide-y divide-slate-100">
      <div class="px-6 py-3 flex gap-4">
        <dt class="text-sm text-slate-500 w-44 shrink-0">Tipo</dt>
        <dd class="text-sm font-medium text-slate-800"><%= counterparty_kind_label(@counterparty.kind) %></dd>
      </div>
      <div class="px-6 py-3 flex gap-4">
        <dt class="text-sm text-slate-500 w-44 shrink-0">CPF/CNPJ</dt>
        <dd class="text-sm font-medium text-slate-800">
          <%= @counterparty.tax_id.present? ? @counterparty.tax_id : content_tag(:span, "Não informado", class: "text-slate-400 italic") %>
        </dd>
      </div>
      <div class="px-6 py-3 flex gap-4">
        <dt class="text-sm text-slate-500 w-44 shrink-0">Status do CPF/CNPJ</dt>
        <dd><%= tax_id_status_badge(@counterparty.tax_id_status) %></dd>
      </div>
      <div class="px-6 py-3 flex gap-4">
        <dt class="text-sm text-slate-500 w-44 shrink-0">Origem do CPF/CNPJ</dt>
        <dd class="text-sm text-slate-700">
          <%= @counterparty.tax_id_source.present? ? tax_id_source_label(@counterparty.tax_id_source) : content_tag(:span, "—", class: "text-slate-400") %>
        </dd>
      </div>
      <% if @counterparty.notes.present? %>
        <div class="px-6 py-3 flex gap-4">
          <dt class="text-sm text-slate-500 w-44 shrink-0">Observações</dt>
          <dd class="text-sm text-slate-700"><%= @counterparty.notes %></dd>
        </div>
      <% end %>
      <div class="px-6 py-3 flex gap-4">
        <dt class="text-sm text-slate-500 w-44 shrink-0">Lançamentos</dt>
        <dd class="text-sm font-medium text-slate-800"><%= @counterparty.financial_transactions.size %></dd>
      </div>
      <div class="px-6 py-3 flex gap-4">
        <dt class="text-sm text-slate-500 w-44 shrink-0">Documentos</dt>
        <dd class="text-sm font-medium text-slate-800"><%= @counterparty.documents.size %></dd>
      </div>
      <div class="px-6 py-3 flex gap-4">
        <dt class="text-sm text-slate-500 w-44 shrink-0">Cadastrado em</dt>
        <dd class="text-sm text-slate-500"><%= @counterparty.created_at.strftime("%d/%m/%Y às %H:%M") %></dd>
      </div>
      <div class="px-6 py-3 flex gap-4">
        <dt class="text-sm text-slate-500 w-44 shrink-0">Atualizado em</dt>
        <dd class="text-sm text-slate-500"><%= @counterparty.updated_at.strftime("%d/%m/%Y às %H:%M") %></dd>
      </div>
    </dl>
  </div>

  <%# Ações %>
  <div class="flex items-center gap-3 mb-6">
    <%= link_to edit_workspace_counterparty_path(current_workspace, @counterparty),
          class: "inline-flex items-center gap-2 px-4 py-2 bg-teal-600 text-white text-sm font-medium rounded-lg hover:bg-teal-700 transition-colors" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125" />
      </svg>
      Editar
    <% end %>

    <%= button_to workspace_counterparty_path(current_workspace, @counterparty),
          method: :delete,
          form: { data: { turbo_confirm: "Excluir #{@counterparty.name}? Lançamentos e documentos vinculados serão mantidos, mas o vínculo será removido." } },
          class: "inline-flex items-center gap-2 px-4 py-2 bg-white border border-red-300 text-red-600 text-sm font-medium rounded-lg hover:bg-red-50 transition-colors cursor-pointer" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
      </svg>
      Excluir
    <% end %>

    <%= link_to "← Voltar", workspace_counterparties_path(current_workspace),
          class: "px-4 py-2 text-sm text-slate-500 hover:text-slate-700 transition-colors" %>
  </div>

  <%# Últimos lançamentos vinculados %>
  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden mb-4">
    <div class="px-6 py-4 border-b border-slate-100">
      <h3 class="text-sm font-semibold text-slate-800">Últimos lançamentos vinculados</h3>
    </div>
    <% if @transactions.empty? %>
      <div class="px-6 py-6 text-center">
        <p class="text-sm text-slate-400">Nenhum lançamento vinculado a este fornecedor/cliente.</p>
      </div>
    <% else %>
      <div class="divide-y divide-slate-100">
        <% @transactions.each do |tx| %>
          <div class="px-6 py-3 flex items-center justify-between gap-4">
            <div class="min-w-0">
              <p class="text-sm font-medium text-slate-800 truncate"><%= tx.description %></p>
              <p class="text-xs text-slate-400 mt-0.5">
                <%= tx.transacted_on&.strftime("%d/%m/%Y") || tx.created_at.strftime("%d/%m/%Y") %>
              </p>
            </div>
            <div class="flex items-center gap-3 shrink-0">
              <span class="text-sm font-semibold <%= tx.income? ? 'text-teal-600' : 'text-red-600' %>">
                <%= tx.income? ? "+" : "-" %><%= format_brl(tx.amount_cents) %>
              </span>
              <%= link_to workspace_financial_transaction_path(current_workspace, tx),
                    class: "text-xs text-slate-400 hover:text-teal-600 transition-colors" do %>
                Ver →
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# Documentos vinculados %>
  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <div class="px-6 py-4 border-b border-slate-100">
      <h3 class="text-sm font-semibold text-slate-800">Documentos vinculados</h3>
    </div>
    <% if @documents.empty? %>
      <div class="px-6 py-6 text-center">
        <p class="text-sm text-slate-400">Nenhum documento vinculado a este fornecedor/cliente.</p>
      </div>
    <% else %>
      <div class="divide-y divide-slate-100">
        <% @documents.each do |doc| %>
          <div class="px-6 py-3 flex items-center justify-between gap-4">
            <div class="min-w-0">
              <% if doc.file.attached? %>
                <p class="text-sm font-medium text-slate-800 truncate"><%= doc.file.blob.filename %></p>
              <% else %>
                <p class="text-sm text-slate-400 italic">Arquivo não disponível</p>
              <% end %>
              <p class="text-xs text-slate-400 mt-0.5"><%= doc.created_at.strftime("%d/%m/%Y") %></p>
            </div>
            <div class="flex items-center gap-3 shrink-0">
              <%= document_status_badge(doc.status) %>
              <%= link_to workspace_document_path(current_workspace, doc),
                    class: "text-xs text-slate-400 hover:text-teal-600 transition-colors" do %>
                Ver →
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

</div>
