<% content_for :title, "Fornecedores e Clientes — #{current_workspace.name}" %>
<% content_for :page_title, "Fornecedores e Clientes" %>

<div class="max-w-6xl">

  <%# Cabeçalho %>
  <div class="flex items-start sm:items-center justify-between mb-4 md:mb-6 gap-3">
    <div>
      <h2 class="text-lg md:text-xl font-bold text-slate-900">Fornecedores e Clientes</h2>
      <p class="text-slate-500 text-sm mt-0.5 hidden sm:block">Gerencie seus fornecedores e clientes do workspace.</p>
    </div>
    <%= link_to new_workspace_counterparty_path(current_workspace),
          class: "shrink-0 inline-flex items-center gap-2 px-3 md:px-4 py-2 bg-teal-600 text-white text-sm font-semibold rounded-lg hover:bg-teal-700 transition-colors" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
      </svg>
      <span class="hidden sm:inline">Novo fornecedor/cliente</span>
      <span class="sm:hidden">Novo</span>
    <% end %>
  </div>

  <%# Cards de resumo %>
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 md:gap-4 mb-4 md:mb-6">
    <div class="bg-white rounded-xl border border-slate-200 p-3 md:p-4">
      <p class="text-xs font-medium text-slate-500 mb-1 uppercase tracking-wide">Total</p>
      <p class="text-lg md:text-xl font-bold text-slate-900"><%= @total_count %></p>
      <p class="text-xs text-slate-400 mt-0.5">Cadastrados</p>
    </div>
    <div class="bg-white rounded-xl border border-slate-200 p-3 md:p-4">
      <p class="text-xs font-medium text-slate-500 mb-1 uppercase tracking-wide">Com CPF/CNPJ</p>
      <p class="text-lg md:text-xl font-bold text-teal-600"><%= @with_tax_id_count %></p>
      <p class="text-xs text-slate-400 mt-0.5">Identificados</p>
    </div>
    <div class="bg-white rounded-xl border border-slate-200 p-3 md:p-4">
      <p class="text-xs font-medium text-slate-500 mb-1 uppercase tracking-wide">Sem CPF/CNPJ</p>
      <p class="text-lg md:text-xl font-bold text-amber-600"><%= @without_tax_id_count %></p>
      <p class="text-xs text-slate-400 mt-0.5">Não informado</p>
    </div>
  </div>

  <%# Busca %>
  <div class="mb-4">
    <%= form_with url: workspace_counterparties_path(current_workspace), method: :get, data: { turbo: false } do |f| %>
      <div class="flex gap-2 md:gap-3">
        <%= f.text_field :q, value: params[:q],
              placeholder: "Buscar por nome…",
              class: "flex-1 px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent" %>
        <%= f.submit "Buscar",
              class: "px-3 md:px-4 py-2 bg-white border border-slate-300 text-slate-700 text-sm font-medium rounded-lg hover:bg-slate-50 transition-colors cursor-pointer" %>
        <% if params[:q].present? %>
          <%= link_to "Limpar", workspace_counterparties_path(current_workspace),
                class: "px-3 py-2 text-sm text-slate-500 hover:text-slate-700 transition-colors" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# Tabela / Estado vazio %>
  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <% if @counterparties.empty? %>
      <div class="p-8 md:p-12 text-center">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" class="w-12 h-12 text-slate-300 mx-auto mb-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z" />
        </svg>
        <h3 class="text-base font-semibold text-slate-700 mb-1">
          <% if params[:q].present? %>
            Nenhum resultado para "<%= params[:q] %>"
          <% else %>
            Nenhum fornecedor ou cliente cadastrado
          <% end %>
        </h3>
        <p class="text-sm text-slate-500 mb-4">
          <% if params[:q].present? %>
            Tente buscar por outro nome.
          <% else %>
            Você ainda não cadastrou fornecedores ou clientes.
          <% end %>
        </p>
        <% unless params[:q].present? %>
          <%= link_to "Novo fornecedor/cliente", new_workspace_counterparty_path(current_workspace),
                class: "inline-flex items-center gap-2 px-4 py-2 bg-teal-600 text-white text-sm font-semibold rounded-lg hover:bg-teal-700 transition-colors" %>
        <% end %>
      </div>
    <% else %>

      <%# Cards mobile %>
      <div class="md:hidden divide-y divide-slate-100">
        <% @counterparties.each do |cp| %>
          <div class="px-4 py-3">
            <div class="flex items-start justify-between gap-2 mb-1">
              <div class="min-w-0 flex-1">
                <p class="font-medium text-slate-800 text-sm truncate"><%= cp.name %></p>
                <p class="text-xs text-slate-400 mt-0.5">
                  <%= counterparty_kind_label(cp.kind) %>
                  <% if cp.tax_id.present? %><span class="mx-1">·</span><%= cp.tax_id %><% end %>
                </p>
              </div>
              <div class="shrink-0">
                <%= tax_id_status_badge(cp.tax_id_status) %>
              </div>
            </div>
            <p class="text-xs text-slate-400 mb-2">
              <%= cp.financial_transactions.size %> lançamentos · <%= cp.documents.size %> documentos · <%= cp.created_at.strftime("%d/%m/%Y") %>
            </p>
            <div class="flex items-center gap-3">
              <%= link_to "Ver", workspace_counterparty_path(current_workspace, cp),
                    class: "text-xs font-medium text-teal-600 hover:text-teal-700" %>
              <%= link_to "Editar", edit_workspace_counterparty_path(current_workspace, cp),
                    class: "text-xs text-slate-400 hover:text-slate-600" %>
              <%= button_to workspace_counterparty_path(current_workspace, cp),
                    method: :delete,
                    form: { data: { turbo_confirm: "Excluir #{cp.name}? Lançamentos e documentos vinculados serão mantidos." } },
                    class: "text-xs text-slate-400 hover:text-red-500 cursor-pointer bg-transparent border-0 p-0" do %>
                Excluir
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <%# Tabela desktop %>
      <div class="hidden md:block overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-slate-200 bg-slate-50">
              <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Nome</th>
              <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Tipo</th>
              <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">CPF/CNPJ</th>
              <th class="text-center px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Status</th>
              <th class="text-center px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Lançamentos</th>
              <th class="text-center px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Documentos</th>
              <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider whitespace-nowrap">Cadastrado em</th>
              <th class="text-right px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Ações</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @counterparties.each do |cp| %>
              <tr class="hover:bg-slate-50/70 transition-colors">
                <td class="px-4 py-3 max-w-xs">
                  <p class="font-medium text-slate-800 truncate"><%= cp.name %></p>
                  <% if cp.notes.present? %>
                    <p class="text-xs text-slate-400 truncate mt-0.5"><%= cp.notes %></p>
                  <% end %>
                </td>
                <td class="px-4 py-3 whitespace-nowrap text-xs text-slate-500">
                  <%= counterparty_kind_label(cp.kind) %>
                </td>
                <td class="px-4 py-3 whitespace-nowrap text-xs text-slate-600">
                  <%= cp.tax_id.present? ? cp.tax_id : content_tag(:span, "—", class: "text-slate-400") %>
                </td>
                <td class="px-4 py-3 text-center">
                  <%= tax_id_status_badge(cp.tax_id_status) %>
                </td>
                <td class="px-4 py-3 text-center text-xs text-slate-600">
                  <%= cp.financial_transactions.size %>
                </td>
                <td class="px-4 py-3 text-center text-xs text-slate-600">
                  <%= cp.documents.size %>
                </td>
                <td class="px-4 py-3 text-xs text-slate-500 whitespace-nowrap">
                  <%= cp.created_at.strftime("%d/%m/%Y") %>
                </td>
                <td class="px-4 py-3 text-right whitespace-nowrap">
                  <div class="inline-flex items-center gap-1">
                    <%= link_to workspace_counterparty_path(current_workspace, cp),
                          class: "p-1.5 text-slate-400 hover:text-teal-600 hover:bg-teal-50 rounded-lg transition-colors",
                          title: "Ver detalhes" do %>
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.641 0-8.573-3.007-9.963-7.178z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                      </svg>
                    <% end %>
                    <%= link_to edit_workspace_counterparty_path(current_workspace, cp),
                          class: "p-1.5 text-slate-400 hover:text-teal-600 hover:bg-teal-50 rounded-lg transition-colors",
                          title: "Editar" do %>
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                        <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125" />
                      </svg>
                    <% end %>
                    <%= button_to workspace_counterparty_path(current_workspace, cp),
                          method: :delete,
                          form: { data: { turbo_confirm: "Excluir #{cp.name}? Lançamentos e documentos vinculados serão mantidos." } },
                          class: "p-1.5 text-slate-400 hover:text-red-500 hover:bg-red-50 rounded-lg transition-colors cursor-pointer bg-transparent border-0",
                          title: "Excluir" do %>
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                      </svg>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

    <% end %>
  </div>

</div>
