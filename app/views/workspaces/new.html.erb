<% content_for :title, "Criar workspace — Aionis" %>

<div class="min-h-screen bg-slate-50 flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-lg bg-white rounded-2xl shadow-lg p-8">
    <div class="text-center mb-8">
      <span class="text-2xl font-bold text-teal-600">Aionis</span>
      <h1 class="text-xl font-bold text-slate-900 mt-3">Configure seu workspace</h1>
      <p class="text-slate-500 text-sm mt-1">Vamos organizar o financeiro da sua empresa.</p>
    </div>

    <%= form_with model: @workspace, url: workspaces_path, html: { class: "space-y-5" } do |f| %>
      <% if @workspace.errors.any? %>
        <div class="bg-red-50 border border-red-200 rounded-lg p-4">
          <p class="text-sm font-medium text-red-800 mb-2">
            <%= pluralize(@workspace.errors.count, "erro") %> impediram o cadastro:
          </p>
          <ul class="list-disc list-inside space-y-1">
            <% @workspace.errors.full_messages.each do |msg| %>
              <li class="text-sm text-red-700"><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= f.label :name, "Nome da empresa ou workspace", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.text_field :name,
              placeholder: "Ex: Meu Negócio, Studio XYZ, João da Silva",
              required: true,
              class: "block w-full rounded-lg border-0 py-2.5 px-3 text-slate-900 ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-teal-600 text-sm" %>
      </div>

      <div>
        <%= f.label :kind, "Tipo de perfil", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.select :kind,
              [
                ["Pessoa Física (CPF)", "cpf"],
                ["MEI — Microempreendedor Individual", "mei"],
                ["Empresa (CNPJ)", "empresa"]
              ],
              { prompt: "Selecione o tipo..." },
              class: "block w-full rounded-lg border-0 py-2.5 px-3 text-slate-900 ring-1 ring-inset ring-slate-300 focus:ring-2 focus:ring-teal-600 text-sm" %>
      </div>

      <%# CPF/CNPJ — SOLICITADO MAS OPCIONAL. Backend nunca bloqueia por ausência. %>
      <div>
        <%= f.label :tax_id, class: "block text-sm font-medium text-slate-700 mb-1" do %>
          CPF/CNPJ
          <span class="text-slate-400 font-normal ml-1">(opcional)</span>
        <% end %>
        <%= f.text_field :tax_id,
              placeholder: "000.000.000-00 ou 00.000.000/0001-00",
              class: "block w-full rounded-lg border-0 py-2.5 px-3 text-slate-900 ring-1 ring-inset ring-slate-300 placeholder:text-slate-400 focus:ring-2 focus:ring-teal-600 text-sm" %>
        <p class="mt-1.5 text-xs text-slate-500 leading-relaxed">
          Informe se souber. Isso ajuda o Aionis a organizar melhor notas e fornecedores,
          mas você pode continuar sem preencher.
        </p>
      </div>

      <div class="pt-2">
        <%= f.submit "Criar workspace e começar",
              class: "w-full bg-teal-600 hover:bg-teal-700 text-white font-semibold py-3 px-4 rounded-xl text-sm transition-colors cursor-pointer" %>
      </div>
    <% end %>

    <% if user_signed_in? && current_user.workspaces.any? %>
      <div class="mt-4 text-center">
        <%= link_to "Voltar para meus workspaces", workspaces_path,
              class: "text-sm text-slate-500 hover:text-slate-700" %>
      </div>
    <% end %>
  </div>
</div>
