<% content_for :title, "Auditoria — #{current_workspace.name}" %>
<% content_for :page_title, "Auditoria" %>

<div class="max-w-6xl">

  <%# Cabeçalho %>
  <div class="mb-4 md:mb-6">
    <h2 class="text-lg md:text-xl font-bold text-slate-900">Auditoria</h2>
    <p class="text-slate-500 text-sm mt-0.5 hidden sm:block">Histórico de todas as operações importantes deste workspace.</p>
  </div>

  <%# Filtros %>
  <div class="mb-4">
    <%= form_with url: workspace_audit_logs_path(current_workspace), method: :get, data: { turbo: false } do |f| %>
      <div class="flex flex-wrap gap-2 md:gap-3">
        <%= f.select :action_type,
              [["Todas as ações", ""]] + AuditLog::ACTIONS.map { |a| [audit_action_label(a), a] },
              { selected: params[:action_type] },
              class: "px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent bg-white" %>
        <%= f.select :origin,
              [["Todas as origens", ""]] + AuditLog::ORIGINS.map { |o| [audit_origin_label(o), o] },
              { selected: params[:origin] },
              class: "px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent bg-white" %>
        <%= f.select :user_id,
              [["Todos os usuários", ""]] + @members.map { |u| [u.name, u.id] },
              { selected: params[:user_id] },
              class: "px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent bg-white" %>
        <%= f.submit "Filtrar",
              class: "px-3 md:px-4 py-2 bg-white border border-slate-300 text-slate-700 text-sm font-medium rounded-lg hover:bg-slate-50 transition-colors cursor-pointer" %>
        <% if params[:action_type].present? || params[:origin].present? || params[:user_id].present? %>
          <%= link_to "Limpar", workspace_audit_logs_path(current_workspace),
                class: "px-3 py-2 text-sm text-slate-500 hover:text-slate-700 transition-colors" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# Tabela / Estado vazio %>
  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <% if @logs.empty? %>
      <div class="p-8 md:p-12 text-center">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" class="w-12 h-12 text-slate-300 mx-auto mb-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z" />
        </svg>
        <h3 class="text-base font-semibold text-slate-700 mb-1">Nenhum registro de auditoria</h3>
        <p class="text-sm text-slate-500">As operações do workspace aparecerão aqui conforme forem realizadas.</p>
      </div>
    <% else %>

      <%# Cards mobile %>
      <div class="md:hidden divide-y divide-slate-100">
        <% @logs.each do |log| %>
          <%= link_to workspace_audit_log_path(current_workspace, log), class: "block px-4 py-3 hover:bg-slate-50/70" do %>
            <div class="flex items-start justify-between gap-2 mb-1">
              <p class="font-medium text-slate-800 text-sm truncate flex-1"><%= log.summary || audit_entity_label(log) %></p>
              <div class="shrink-0"><%= audit_action_badge(log.action) %></div>
            </div>
            <p class="text-xs text-slate-400">
              <%= audit_actor_label(log) %> · <%= log.created_at.strftime("%d/%m/%Y %H:%M") %>
              <% if log.confidence.present? %><span class="mx-1">·</span>conf. <%= log.confidence %><% end %>
            </p>
          <% end %>
        <% end %>
      </div>

      <%# Tabela desktop %>
      <div class="hidden md:block overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-slate-200 bg-slate-50">
              <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Quando</th>
              <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Ação</th>
              <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Descrição</th>
              <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Autor</th>
              <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Origem</th>
              <th class="text-right px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @logs.each do |log| %>
              <tr class="hover:bg-slate-50/70 transition-colors">
                <td class="px-4 py-3 whitespace-nowrap text-xs text-slate-500"><%= log.created_at.strftime("%d/%m/%Y %H:%M") %></td>
                <td class="px-4 py-3 whitespace-nowrap"><%= audit_action_badge(log.action) %></td>
                <td class="px-4 py-3 max-w-md">
                  <p class="text-slate-700 truncate"><%= log.summary || audit_entity_label(log) %></p>
                  <% if log.reason.present? %><p class="text-xs text-slate-400 truncate"><%= log.reason %></p><% end %>
                </td>
                <td class="px-4 py-3 text-xs text-slate-600 whitespace-nowrap"><%= audit_actor_label(log) %></td>
                <td class="px-4 py-3 text-xs text-slate-500 whitespace-nowrap"><%= audit_origin_label(log.origin) %></td>
                <td class="px-4 py-3 text-right whitespace-nowrap">
                  <%= link_to "Ver", workspace_audit_log_path(current_workspace, log),
                        class: "text-xs font-medium text-teal-600 hover:text-teal-700" %>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

    <% end %>
  </div>

  <%# Paginação %>
  <% per_page = Workspaces::AuditLogsController::PER_PAGE %>
  <% if @total > per_page %>
    <div class="flex items-center justify-between mt-4 text-sm">
      <p class="text-slate-500">
        <%= (@page - 1) * per_page + 1 %>–<%= [@page * per_page, @total].min %> de <%= @total %>
      </p>
      <div class="flex gap-2">
        <% if @page > 1 %>
          <%= link_to "Anterior", workspace_audit_logs_path(current_workspace, request.query_parameters.merge(page: @page - 1)),
                class: "px-3 py-2 bg-white border border-slate-300 text-slate-700 rounded-lg hover:bg-slate-50 transition-colors" %>
        <% end %>
        <% if @has_next %>
          <%= link_to "Próxima", workspace_audit_logs_path(current_workspace, request.query_parameters.merge(page: @page + 1)),
                class: "px-3 py-2 bg-white border border-slate-300 text-slate-700 rounded-lg hover:bg-slate-50 transition-colors" %>
        <% end %>
      </div>
    </div>
  <% end %>

</div>
