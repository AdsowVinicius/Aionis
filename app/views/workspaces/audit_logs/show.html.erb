<% content_for :title, "Registro de auditoria — #{current_workspace.name}" %>
<% content_for :page_title, "Registro de auditoria" %>

<div class="mx-auto max-w-3xl">
  <div class="flex items-center gap-3 mb-6">
    <%= link_to workspace_audit_logs_path(current_workspace),
          class: "text-slate-400 hover:text-slate-600 transition-colors" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
      </svg>
    <% end %>
    <div class="flex items-center gap-2">
      <h2 class="text-xl font-bold text-slate-900"><%= audit_action_label(@log.action) %></h2>
      <%= audit_action_badge(@log.action) %>
    </div>
  </div>

  <%# Resumo %>
  <div class="bg-white rounded-xl border border-slate-200 p-6 mb-4">
    <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-3 text-sm">
      <div>
        <dt class="text-xs text-slate-400 uppercase tracking-wide">Quando</dt>
        <dd class="text-slate-800"><%= @log.created_at.strftime("%d/%m/%Y %H:%M:%S") %></dd>
      </div>
      <div>
        <dt class="text-xs text-slate-400 uppercase tracking-wide">Autor</dt>
        <dd class="text-slate-800"><%= audit_actor_label(@log) %></dd>
      </div>
      <div>
        <dt class="text-xs text-slate-400 uppercase tracking-wide">Origem</dt>
        <dd class="text-slate-800"><%= audit_origin_label(@log.origin) %></dd>
      </div>
      <div>
        <dt class="text-xs text-slate-400 uppercase tracking-wide">Entidade</dt>
        <dd class="text-slate-800"><%= audit_entity_label(@log) %></dd>
      </div>
      <% if @log.provider.present? %>
        <div>
          <dt class="text-xs text-slate-400 uppercase tracking-wide">Provedor</dt>
          <dd class="text-slate-800"><%= @log.provider %></dd>
        </div>
      <% end %>
      <% if @log.confidence.present? %>
        <div>
          <dt class="text-xs text-slate-400 uppercase tracking-wide">Confiança</dt>
          <dd class="text-slate-800"><%= @log.confidence %>/100</dd>
        </div>
      <% end %>
    </dl>

    <% if @log.reason.present? %>
      <div class="mt-4 pt-4 border-t border-slate-100">
        <dt class="text-xs text-slate-400 uppercase tracking-wide mb-1">Motivo</dt>
        <dd class="text-sm text-slate-700"><%= @log.reason %></dd>
      </div>
    <% end %>
  </div>

  <%# Diff antes/depois %>
  <% if @log.before_data.present? || @log.after_data.present? %>
    <div class="bg-white rounded-xl border border-slate-200 p-6 mb-4">
      <h3 class="text-sm font-semibold text-slate-700 mb-3">Alterações</h3>
      <% keys = (@log.before_data.keys | @log.after_data.keys).sort %>
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-slate-200 text-xs text-slate-500 uppercase tracking-wider">
              <th class="text-left py-2 pr-4">Campo</th>
              <th class="text-left py-2 pr-4">Antes</th>
              <th class="text-left py-2">Depois</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% keys.each do |k| %>
              <tr>
                <td class="py-2 pr-4 font-medium text-slate-600 align-top"><%= k %></td>
                <td class="py-2 pr-4 text-slate-500 align-top break-words"><%= @log.before_data[k].presence || "—" %></td>
                <td class="py-2 text-slate-800 align-top break-words"><%= @log.after_data[k].presence || "—" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% end %>

  <%# Metadados %>
  <% if @log.metadata.present? %>
    <div class="bg-white rounded-xl border border-slate-200 p-6">
      <h3 class="text-sm font-semibold text-slate-700 mb-3">Metadados</h3>
      <pre class="text-xs text-slate-600 bg-slate-50 rounded-lg p-3 overflow-x-auto"><%= JSON.pretty_generate(@log.metadata) %></pre>
    </div>
  <% end %>
</div>
