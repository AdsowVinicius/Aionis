<%
  border = case alert.severity
           when :critical then "border-l-4 border-red-400"
           when :warning  then "border-l-4 border-amber-400"
           else                "border-l-4 border-blue-400"
           end
  badge_css = case alert.severity
              when :critical then "bg-red-100 text-red-700"
              when :warning  then "bg-amber-100 text-amber-700"
              else                "bg-blue-100 text-blue-700"
              end
  path = alert_link_path(alert, current_workspace)
%>
<div class="bg-white rounded-lg border border-slate-200 <%= border %> px-4 py-3 flex items-start justify-between gap-3">
  <div class="flex-1 min-w-0">
    <p class="text-sm font-semibold text-slate-800"><%= alert.title %></p>
    <p class="text-xs text-slate-500 mt-0.5"><%= alert.description %></p>
    <% if alert.amount_cents > 0 %>
      <p class="text-xs font-medium text-slate-600 mt-1"><%= format_brl(alert.amount_cents) %></p>
    <% end %>
  </div>
  <div class="flex items-center gap-2 shrink-0">
    <span class="inline-flex items-center justify-center min-w-[1.5rem] h-6 px-1.5 rounded-full text-xs font-bold <%= badge_css %>">
      <%= alert.count %>
    </span>
    <%= link_to "Ver →", path, class: "text-xs text-teal-600 hover:text-teal-700 hover:underline" %>
  </div>
</div>
