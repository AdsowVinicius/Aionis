<%= form_with model: [current_workspace, @payable], data: { turbo: false } do |f| %>
  <% if @payable.errors.any? %>
    <div class="mb-4 bg-red-50 border border-red-200 rounded-lg px-4 py-3">
      <p class="text-sm font-medium text-red-700 mb-1">Corrija os erros abaixo:</p>
      <ul class="text-sm text-red-600 list-disc list-inside">
        <% @payable.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="space-y-4">

    <div>
      <%= f.label :description, "Descrição", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.text_field :description,
            placeholder: "Ex: Aluguel do escritório",
            class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-teal-500" %>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <%= f.label :amount_brl, "Valor (R$)", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.text_field :amount_brl,
              value: @payable.amount_brl > 0 ? "%.2f" % @payable.amount_brl : "",
              placeholder: "0,00",
              class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-teal-500" %>
      </div>
      <div>
        <%= f.label :due_on, "Vencimento", class: "block text-sm font-medium text-slate-700 mb-1" %>
        <%= f.date_field :due_on,
              class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-teal-500" %>
      </div>
    </div>

    <div>
      <%= f.label :category_id, "Categoria", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.select :category_id,
            options_for_select(
              @categories.map { |c| [c.name, c.id] },
              @payable.category_id
            ),
            { include_blank: "— Selecione (opcional)" },
            class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-teal-500" %>
    </div>

    <div>
      <%= f.label :counterparty_id, "Fornecedor / Cliente", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.select :counterparty_id,
            options_for_select(
              @counterparties.map { |cp| [cp.name, cp.id] },
              @payable.counterparty_id
            ),
            { include_blank: "— Selecione (opcional)" },
            class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-teal-500" %>
    </div>

    <div>
      <%= f.label :document_id, "Documento vinculado", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.select :document_id,
            options_for_select(
              @documents.map { |d|
                label = d.file.attached? ? d.file.blob.filename.to_s : "Documento ##{d.id}"
                [label, d.id]
              },
              @payable.document_id
            ),
            { include_blank: "— Selecione (opcional)" },
            class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-teal-500" %>
    </div>

    <div>
      <%= f.label :notes, "Observações", class: "block text-sm font-medium text-slate-700 mb-1" %>
      <%= f.text_area :notes,
            rows: 3,
            placeholder: "Informações adicionais (opcional)",
            class: "w-full px-3 py-2 border border-slate-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-teal-500 resize-none" %>
    </div>

    <div class="flex items-center gap-3 pt-2">
      <%= f.submit @payable.new_record? ? "Criar conta a pagar" : "Salvar alterações",
            class: "px-5 py-2 bg-teal-600 text-white text-sm font-semibold rounded-lg hover:bg-teal-700 transition-colors cursor-pointer" %>
      <%= link_to "Cancelar", workspace_payables_path(current_workspace),
            class: "px-4 py-2 text-sm text-slate-500 hover:text-slate-700 transition-colors" %>
    </div>

  </div>
<% end %>
