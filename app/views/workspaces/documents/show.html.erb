<% content_for :title, "Documento ##{@document.id} — #{current_workspace.name}" %>
<% content_for :page_title, "Detalhes do documento" %>

<div class="max-w-2xl">
  <div class="flex items-center gap-3 mb-6">
    <%= link_to workspace_documents_path(current_workspace),
          class: "text-slate-400 hover:text-slate-600 transition-colors" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
      </svg>
    <% end %>
    <h2 class="text-xl font-bold text-slate-900">Detalhes do documento</h2>
  </div>

  <%# Preview para imagens %>
  <% if @document.file.attached? && @document.file.blob.content_type.start_with?("image/") %>
    <div class="bg-white rounded-xl border border-slate-200 p-4 mb-4 text-center">
      <%= image_tag url_for(@document.file),
            class: "max-h-72 max-w-full mx-auto rounded-lg object-contain",
            alt: @document.file.blob.filename.to_s %>
    </div>
  <% end %>

  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden mb-4">

    <%# Cabeçalho %>
    <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between gap-4">
      <div class="min-w-0">
        <% if @document.file.attached? %>
          <p class="font-semibold text-slate-900 truncate"><%= @document.file.blob.filename %></p>
          <p class="text-xs text-slate-400 mt-0.5">
            <%= document_content_type_label(@document.file.blob.content_type) %> ·
            <%= format_file_size(@document.file.blob.byte_size) %>
          </p>
        <% else %>
          <p class="font-semibold text-slate-500 italic">Arquivo não disponível</p>
        <% end %>
      </div>
      <%= document_status_badge(@document.status) %>
    </div>

    <%# Detalhes %>
    <dl class="divide-y divide-slate-100">
      <div class="px-6 py-3 flex gap-4">
        <dt class="text-sm text-slate-500 w-44 shrink-0">Tipo do arquivo</dt>
        <dd class="text-sm font-medium text-slate-800">
          <% if @document.file.attached? %>
            <%= document_content_type_label(@document.file.blob.content_type) %>
            <span class="text-slate-400 text-xs ml-1">(<%= @document.file.blob.content_type %>)</span>
          <% else %>
            —
          <% end %>
        </dd>
      </div>
      <div class="px-6 py-3 flex gap-4">
        <dt class="text-sm text-slate-500 w-44 shrink-0">Tamanho</dt>
        <dd class="text-sm font-medium text-slate-800">
          <%= @document.file.attached? ? format_file_size(@document.file.blob.byte_size) : "—" %>
        </dd>
      </div>
      <div class="px-6 py-3 flex gap-4">
        <dt class="text-sm text-slate-500 w-44 shrink-0">Status</dt>
        <dd><%= document_status_badge(@document.status) %></dd>
      </div>
      <div class="px-6 py-3 flex gap-4">
        <dt class="text-sm text-slate-500 w-44 shrink-0">Origem</dt>
        <dd class="text-sm font-medium text-slate-800 capitalize">
          <%= { "web" => "Portal web", "email" => "E-mail", "whatsapp" => "WhatsApp", "manual" => "Manual" }[@document.source] || @document.source %>
        </dd>
      </div>
      <div class="px-6 py-3 flex gap-4">
        <dt class="text-sm text-slate-500 w-44 shrink-0">Workspace</dt>
        <dd class="text-sm font-medium text-slate-800"><%= current_workspace.name %></dd>
      </div>
      <% if @document.notes.present? %>
        <div class="px-6 py-3 flex gap-4">
          <dt class="text-sm text-slate-500 w-44 shrink-0">Observações</dt>
          <dd class="text-sm text-slate-700"><%= @document.notes %></dd>
        </div>
      <% end %>
      <div class="px-6 py-3 flex gap-4">
        <dt class="text-sm text-slate-500 w-44 shrink-0">Enviado em</dt>
        <dd class="text-sm text-slate-500"><%= @document.created_at.strftime("%d/%m/%Y às %H:%M") %></dd>
      </div>
      <div class="px-6 py-3 flex gap-4">
        <dt class="text-sm text-slate-500 w-44 shrink-0">Atualizado em</dt>
        <dd class="text-sm text-slate-500"><%= @document.updated_at.strftime("%d/%m/%Y às %H:%M") %></dd>
      </div>
    </dl>
  </div>

  <%# Ações %>
  <div class="flex flex-wrap items-center gap-3 mb-6">

    <%# Criar lançamento vinculado %>
    <%= link_to new_workspace_financial_transaction_path(current_workspace, document_id: @document.id),
          class: "inline-flex items-center gap-2 px-4 py-2 bg-teal-600 text-white text-sm font-medium rounded-lg hover:bg-teal-700 transition-colors" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
      </svg>
      Criar lançamento vinculado
    <% end %>

    <%# Botão processar documento (somente quando faz sentido processar) %>
    <% if @document.pending? || @document.failed? || @document.review? %>
      <%= button_to trigger_workspace_document_path(current_workspace, @document),
            method: :post,
            class: "inline-flex items-center gap-2 px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors cursor-pointer border-0" do %>
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 5.653c0-.856.917-1.398 1.667-.986l11.54 6.347a1.125 1.125 0 0 1 0 1.972l-11.54 6.347a1.125 1.125 0 0 1-1.667-.986V5.653Z" />
        </svg>
        Processar documento
      <% end %>
    <% end %>

    <%# Botão abrir/baixar arquivo %>
    <% if @document.file.attached? %>
      <% if @document.file.blob.content_type == "application/pdf" %>
        <%= link_to url_for(@document.file.blob),
              target: "_blank", rel: "noopener",
              class: "inline-flex items-center gap-2 px-4 py-2 bg-teal-600 text-white text-sm font-medium rounded-lg hover:bg-teal-700 transition-colors" do %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
          </svg>
          Abrir PDF
        <% end %>
      <% elsif @document.file.blob.content_type.start_with?("image/") %>
        <%= link_to rails_blob_path(@document.file, disposition: "attachment"),
              class: "inline-flex items-center gap-2 px-4 py-2 bg-teal-600 text-white text-sm font-medium rounded-lg hover:bg-teal-700 transition-colors" do %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
          </svg>
          Baixar imagem
        <% end %>
      <% else %>
        <%= link_to rails_blob_path(@document.file, disposition: "attachment"),
              class: "inline-flex items-center gap-2 px-4 py-2 bg-teal-600 text-white text-sm font-medium rounded-lg hover:bg-teal-700 transition-colors" do %>
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
          </svg>
          Baixar arquivo
        <% end %>
      <% end %>
    <% end %>

    <%# Excluir %>
    <%= button_to workspace_document_path(current_workspace, @document),
          method: :delete,
          form: { data: { turbo_confirm: "Excluir este documento? Esta ação não pode ser desfeita." } },
          class: "inline-flex items-center gap-2 px-4 py-2 bg-white border border-red-300 text-red-600 text-sm font-medium rounded-lg hover:bg-red-50 transition-colors cursor-pointer" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
      </svg>
      Excluir documento
    <% end %>

    <%= link_to "← Voltar para documentos", workspace_documents_path(current_workspace),
          class: "px-4 py-2 text-sm text-slate-500 hover:text-slate-700 transition-colors" %>
  </div>

  <%# Lançamentos vinculados %>
  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden mb-4">
    <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
      <h3 class="text-sm font-semibold text-slate-800">Lançamentos vinculados</h3>
      <span class="text-xs text-slate-400 font-medium"><%= @transactions.size %> <%= @transactions.size == 1 ? "lançamento" : "lançamentos" %></span>
    </div>
    <% if @transactions.empty? %>
      <div class="px-6 py-6 text-center">
        <p class="text-sm text-slate-400">Nenhum lançamento vinculado a este documento.</p>
        <p class="text-xs text-slate-400 mt-1">
          <%= link_to "Criar lançamento vinculado",
                new_workspace_financial_transaction_path(current_workspace, document_id: @document.id),
                class: "text-teal-600 hover:underline" %>
        </p>
      </div>
    <% else %>
      <div class="divide-y divide-slate-100">
        <% @transactions.each do |tx| %>
          <div class="px-6 py-3 flex items-center justify-between gap-4">
            <div class="min-w-0">
              <p class="text-sm font-medium text-slate-800 truncate"><%= tx.description %></p>
              <p class="text-xs text-slate-400 mt-0.5">
                <%= tx.transacted_on&.strftime("%d/%m/%Y") || tx.created_at.strftime("%d/%m/%Y") %>
              </p>
            </div>
            <div class="flex items-center gap-3 shrink-0">
              <span class="text-sm font-semibold <%= tx.income? ? 'text-teal-600' : 'text-red-600' %>">
                <%= tx.income? ? "+" : "−" %><%= format_brl(tx.amount_cents) %>
              </span>
              <%= link_to workspace_financial_transaction_path(current_workspace, tx),
                    class: "text-xs text-slate-400 hover:text-teal-600 transition-colors" do %>
                Ver →
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# Histórico de extrações %>
  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <div class="px-6 py-4 border-b border-slate-100 flex items-center justify-between">
      <div>
        <h3 class="text-sm font-semibold text-slate-800">Histórico de extrações</h3>
        <p class="text-xs text-slate-400 mt-0.5">
          O pipeline interno já está preparado. A leitura automática por OCR/IA será implementada em uma próxima etapa.
        </p>
      </div>
      <span class="text-xs text-slate-400 font-medium"><%= @extractions.size %> <%= @extractions.size == 1 ? "extração" : "extrações" %></span>
    </div>

    <% if @extractions.empty? %>
      <div class="px-6 py-8 text-center">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" class="w-10 h-10 text-slate-200 mx-auto mb-3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0112 15a9.065 9.065 0 00-6.23-.693L5 14.5m14.8.8l1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0112 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5" />
        </svg>
        <p class="text-sm text-slate-500 font-medium">Nenhuma extração foi executada para este documento.</p>
        <p class="text-xs text-slate-400 mt-1">Clique em "Processar documento" para iniciar.</p>
      </div>
    <% else %>
      <div class="divide-y divide-slate-100">
        <% @extractions.each do |extraction| %>
          <div class="px-6 py-4">
            <div class="flex items-start justify-between gap-4 mb-2">
              <div class="flex items-center gap-2">
                <%= extraction_status_badge(extraction.status) %>
                <% if extraction.processor_name.present? %>
                  <span class="text-xs text-slate-400">
                    <%= extraction.processor_name %>
                    <% if extraction.processor_version.present? %>
                      v<%= extraction.processor_version %>
                    <% end %>
                  </span>
                <% end %>
              </div>
              <% if extraction.confidence_score %>
                <span class="text-xs text-slate-500 shrink-0">Confiança: <strong><%= extraction.confidence_score %>%</strong></span>
              <% end %>
            </div>

            <% if extraction.extracted_data.present? && extraction.extracted_data["message"].present? %>
              <p class="text-xs text-slate-500 bg-slate-50 rounded-lg px-3 py-2 mt-2">
                <%= extraction.extracted_data["message"] %>
              </p>
            <% end %>

            <% if extraction.error_message.present? %>
              <p class="text-xs text-red-600 bg-red-50 rounded-lg px-3 py-2 mt-2">
                <strong>Erro:</strong> <%= extraction.error_message %>
              </p>
            <% end %>

            <div class="flex items-center gap-4 mt-2 text-xs text-slate-400">
              <% if extraction.started_at %>
                <span>Iniciado: <%= extraction.started_at.strftime("%d/%m/%Y %H:%M") %></span>
              <% end %>
              <% if extraction.finished_at %>
                <span>Finalizado: <%= extraction.finished_at.strftime("%d/%m/%Y %H:%M") %></span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

</div>
