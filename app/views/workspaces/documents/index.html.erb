<% content_for :title, "Documentos — #{current_workspace.name}" %>
<% content_for :page_title, "Documentos" %>

<div class="max-w-6xl">

  <%# Cabeçalho %>
  <div class="flex items-start sm:items-center justify-between mb-4 md:mb-6 gap-3">
    <div>
      <h2 class="text-lg md:text-xl font-bold text-slate-900">Documentos</h2>
      <p class="text-slate-500 text-sm mt-0.5 hidden sm:block">Notas, recibos, boletos e comprovantes do workspace.</p>
    </div>
    <%= link_to new_workspace_document_path(current_workspace),
          class: "shrink-0 inline-flex items-center gap-2 px-3 md:px-4 py-2 bg-teal-600 text-white text-sm font-semibold rounded-lg hover:bg-teal-700 transition-colors" do %>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-4 h-4">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5m-13.5-9L12 3m0 0l4.5 4.5M12 3v13.5" />
      </svg>
      <span class="hidden sm:inline">Enviar documento</span>
      <span class="sm:hidden">Enviar</span>
    <% end %>
  </div>

  <%# Cards de resumo %>
  <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 md:gap-4 mb-4 md:mb-6">
    <div class="bg-white rounded-xl border border-slate-200 p-3 md:p-4">
      <p class="text-xs font-medium text-slate-500 mb-1 uppercase tracking-wide">Total</p>
      <p class="text-lg md:text-xl font-bold text-slate-900"><%= @total_count %></p>
      <p class="text-xs text-slate-400 mt-0.5 hidden sm:block">Documentos enviados</p>
    </div>
    <div class="bg-white rounded-xl border border-slate-200 p-3 md:p-4">
      <p class="text-xs font-medium text-slate-500 mb-1 uppercase tracking-wide">Pendentes</p>
      <p class="text-lg md:text-xl font-bold text-amber-600"><%= @pending_count %></p>
      <p class="text-xs text-slate-400 mt-0.5 hidden sm:block">Aguardando processamento</p>
    </div>
    <div class="bg-white rounded-xl border border-slate-200 p-3 md:p-4">
      <p class="text-xs font-medium text-slate-500 mb-1 uppercase tracking-wide">Processados</p>
      <p class="text-lg md:text-xl font-bold text-teal-600"><%= @processed_count %></p>
      <p class="text-xs text-slate-400 mt-0.5 hidden sm:block">Processados com sucesso</p>
    </div>
    <div class="bg-white rounded-xl border border-slate-200 p-3 md:p-4">
      <p class="text-xs font-medium text-slate-500 mb-1 uppercase tracking-wide">Com erro</p>
      <p class="text-lg md:text-xl font-bold text-red-600"><%= @failed_count %></p>
      <p class="text-xs text-slate-400 mt-0.5 hidden sm:block">Falha no processamento</p>
    </div>
  </div>

  <%# Tabela / Estado vazio %>
  <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
    <% if @documents.empty? %>
      <div class="p-8 md:p-12 text-center">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" class="w-12 h-12 text-slate-300 mx-auto mb-4">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z" />
        </svg>
        <h3 class="text-base font-semibold text-slate-700 mb-1">Nenhum documento enviado</h3>
        <p class="text-sm text-slate-500 mb-4">
          Você ainda não enviou documentos. Envie uma nota, recibo, boleto ou comprovante para começar.
        </p>
        <%= link_to "Enviar documento", new_workspace_document_path(current_workspace),
              class: "inline-flex items-center gap-2 px-4 py-2 bg-teal-600 text-white text-sm font-semibold rounded-lg hover:bg-teal-700 transition-colors" %>
      </div>
    <% else %>

      <%# Cards mobile %>
      <div class="md:hidden divide-y divide-slate-100">
        <% @documents.each do |doc| %>
          <div class="px-4 py-3">
            <div class="flex items-start justify-between gap-2 mb-1">
              <div class="min-w-0 flex-1">
                <% if doc.file.attached? %>
                  <p class="font-medium text-slate-800 text-sm truncate"><%= doc.file.blob.filename %></p>
                  <p class="text-xs text-slate-400 mt-0.5">
                    <%= document_content_type_label(doc.file.blob.content_type) %>
                    <span class="mx-1">·</span>
                    <%= format_file_size(doc.file.blob.byte_size) %>
                  </p>
                <% else %>
                  <p class="text-sm text-slate-400 italic">Arquivo não disponível</p>
                <% end %>
                <p class="text-xs text-slate-400 mt-0.5"><%= doc.created_at.strftime("%d/%m/%Y %H:%M") %></p>
              </div>
              <div class="shrink-0 flex flex-col items-end gap-1">
                <%= document_status_badge(doc.status) %>
                <% ext = doc.latest_extraction %>
                <% if ext %>
                  <%= extraction_status_badge(ext.status) %>
                <% end %>
              </div>
            </div>
            <div class="flex items-center gap-3 mt-1.5">
              <%= link_to "Ver detalhes", workspace_document_path(current_workspace, doc),
                    class: "text-xs font-medium text-teal-600 hover:text-teal-700" %>
              <% if doc.file.attached? %>
                <%= link_to "Baixar", rails_blob_path(doc.file, disposition: "attachment"),
                      class: "text-xs text-slate-400 hover:text-slate-600" %>
              <% end %>
              <%= button_to workspace_document_path(current_workspace, doc),
                    method: :delete,
                    form: { data: { turbo_confirm: "Excluir este documento? Esta ação não pode ser desfeita." } },
                    class: "text-xs text-slate-400 hover:text-red-500 cursor-pointer bg-transparent border-0 p-0" do %>
                Excluir
              <% end %>
            </div>
          </div>
        <% end %>
      </div>

      <%# Tabela desktop %>
      <div class="hidden md:block overflow-x-auto">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-slate-200 bg-slate-50">
              <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Arquivo</th>
              <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Tipo</th>
              <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Tamanho</th>
              <th class="text-center px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Status</th>
              <th class="text-center px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Extração</th>
              <th class="text-left px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider whitespace-nowrap">Enviado em</th>
              <th class="text-right px-4 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">Ações</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% @documents.each do |doc| %>
              <tr class="hover:bg-slate-50/70 transition-colors">
                <td class="px-4 py-3 max-w-xs">
                  <% if doc.file.attached? %>
                    <p class="font-medium text-slate-800 truncate"><%= doc.file.blob.filename %></p>
                    <% if doc.notes.present? %>
                      <p class="text-xs text-slate-400 truncate mt-0.5"><%= doc.notes %></p>
                    <% end %>
                  <% else %>
                    <p class="text-slate-400 italic text-xs">Arquivo não disponível</p>
                  <% end %>
                </td>
                <td class="px-4 py-3 whitespace-nowrap text-xs text-slate-500">
                  <%= doc.file.attached? ? document_content_type_label(doc.file.blob.content_type) : "—" %>
                </td>
                <td class="px-4 py-3 whitespace-nowrap text-xs text-slate-500">
                  <%= doc.file.attached? ? format_file_size(doc.file.blob.byte_size) : "—" %>
                </td>
                <td class="px-4 py-3 text-center">
                  <%= document_status_badge(doc.status) %>
                </td>
                <td class="px-4 py-3 text-center">
                  <% ext = doc.latest_extraction %>
                  <% if ext %>
                    <%= extraction_status_badge(ext.status) %>
                  <% else %>
                    <span class="text-xs text-slate-400">Sem extração</span>
                  <% end %>
                </td>
                <td class="px-4 py-3 text-xs text-slate-500 whitespace-nowrap">
                  <%= doc.created_at.strftime("%d/%m/%Y %H:%M") %>
                </td>
                <td class="px-4 py-3 text-right whitespace-nowrap">
                  <div class="inline-flex items-center gap-1">
                    <%= link_to workspace_document_path(current_workspace, doc),
                          class: "p-1.5 text-slate-400 hover:text-teal-600 hover:bg-teal-50 rounded-lg transition-colors",
                          title: "Ver detalhes" do %>
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M2.036 12.322a1.012 1.012 0 010-.639C3.423 7.51 7.36 4.5 12 4.5c4.638 0 8.573 3.007 9.963 7.178.07.207.07.431 0 .639C20.577 16.49 16.64 19.5 12 19.5c-4.641 0-8.573-3.007-9.963-7.178z" />
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                      </svg>
                    <% end %>
                    <% if doc.file.attached? %>
                      <%= link_to rails_blob_path(doc.file, disposition: "attachment"),
                            class: "p-1.5 text-slate-400 hover:text-teal-600 hover:bg-teal-50 rounded-lg transition-colors",
                            title: "Baixar arquivo" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M16.5 12L12 16.5m0 0L7.5 12m4.5 4.5V3" />
                        </svg>
                      <% end %>
                    <% end %>
                    <%= button_to workspace_document_path(current_workspace, doc),
                          method: :delete,
                          form: { data: { turbo_confirm: "Excluir este documento? Esta ação não pode ser desfeita." } },
                          class: "p-1.5 text-slate-400 hover:text-red-500 hover:bg-red-50 rounded-lg transition-colors cursor-pointer bg-transparent border-0",
                          title: "Excluir" do %>
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M14.74 9l-.346 9m-4.788 0L9.26 9m9.968-3.21c.342.052.682.107 1.022.166m-1.022-.165L18.16 19.673a2.25 2.25 0 01-2.244 2.077H8.084a2.25 2.25 0 01-2.244-2.077L4.772 5.79m14.456 0a48.108 48.108 0 00-3.478-.397m-12 .562c.34-.059.68-.114 1.022-.165m0 0a48.11 48.11 0 013.478-.397m7.5 0v-.916c0-1.18-.91-2.164-2.09-2.201a51.964 51.964 0 00-3.32 0c-1.18.037-2.09 1.022-2.09 2.201v.916m7.5 0a48.667 48.667 0 00-7.5 0" />
                      </svg>
                    <% end %>
                  </div>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>

    <% end %>
  </div>

</div>
