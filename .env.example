# =============================================================================
# Aionis — variáveis de ambiente (arquivo ÚNICO por projeto)
# -----------------------------------------------------------------------------
# Como usar:
#   1. Copie este arquivo para `.env`   ->   cp .env.example .env
#   2. Preencha os valores reais no `.env` (ele é IGNORADO pelo git; nunca commite segredos).
#   3. O `.env` é carregado automaticamente pela gem dotenv-rails (dev/test).
#
# Em produção NÃO use este arquivo: configure as variáveis no seu provedor/host
# (ou nos secrets do Kamal). Segredos jamais vão para o git (CLAUDE.md §9).
#
# Deixe uma variável em branco/comentada para usar o provedor "null" (stub seguro,
# sem chamada externa). Assim o app sobe mesmo sem integrações configuradas.
# =============================================================================


# =============================================================================
# WHATSAPP — número ÚNICO/global do Aionis (a pessoa conversa com esse número).
# O remetente é identificado pelo número dele (Workspace#whatsapp_number).
# =============================================================================

# Provedor ativo: meta_cloud (oficial) | evolution (self-hosted) | null (desligado)
WHATSAPP_PROVIDER=meta_cloud

# Dry-run do ENVIO: quando true, o Aionis NÃO chama a Meta para enviar respostas
# — apenas loga a mensagem ([WHATSAPP_DRY_RUN]) e marca a OutgoingMessage como
# "dry_run". Serve para testar o pipeline de ponta a ponta quando a conta de
# teste da Meta está bloqueada para envio (ex.: erro 130497, remetente EUA →
# destinatário BR). O RECEBIMENTO por webhook continua normal. Default: true em
# development/test, false em produção. Deixe em branco para usar o default.
WHATSAPP_DRY_RUN=

# --- Meta WhatsApp Cloud API (recomendado) -----------------------------------
# Onde conseguir: https://developers.facebook.com  ->  crie um App do tipo
# "Business"  ->  adicione o produto "WhatsApp".
#
# ID do número de telefone. Em: App > WhatsApp > "Configuração da API"
# (API Setup), campo "Identificação do número de telefone" (Phone number ID).
META_PHONE_NUMBER_ID=

# Token de acesso. Para testes: o token temporário na mesma tela "API Setup".
# Para produção (permanente): Configurações do Negócio > Usuários > Usuários do
# sistema > gerar token com as permissões whatsapp_business_messaging e
# whatsapp_business_management.
META_ACCESS_TOKEN=

# Segredo do app (valida a assinatura HMAC dos webhooks). Em:
# App > Configurações > Básico > "Chave Secreta do Aplicativo" (App Secret).
META_APP_SECRET=

# Token de verificação do webhook: VOCÊ INVENTA uma string qualquer (ex.: uma
# senha aleatória) e repete o MESMO valor no painel da Meta ao configurar o
# webhook (campo "Verify token"). Serve só para o handshake de verificação.
META_VERIFY_TOKEN=

# Versão da Graph API (opcional; padrão v21.0).
META_GRAPH_VERSION=v21.0

# >>> Configuração do webhook no painel da Meta (App > WhatsApp > Configuration):
#     Callback URL:  https://SEU_DOMINIO/webhooks/whatsapp/meta
#     Verify token:  o mesmo valor de META_VERIFY_TOKEN acima
#     Webhook fields: assine o campo "messages"
#     (em dev, exponha o localhost com ngrok/cloudflared para ter uma URL https)

# --- Evolution API (alternativa self-hosted; só se WHATSAPP_PROVIDER=evolution)
EVOLUTION_BASE_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=
EVOLUTION_WEBHOOK_TOKEN=
EVOLUTION_TIMEOUT=15


# =============================================================================
# IA — apenas fallback do motor de classificação (CLAUDE.md §4).
# =============================================================================
# Provedor: anthropic | null (desligado). Com "null", classifica só por regras/histórico.
AI_PROVIDER=null

# Chave da API Anthropic (Claude). Onde conseguir: https://console.anthropic.com
# -> Settings > API Keys.
AI_API_KEY=
AI_MODEL=claude-haiku-4-5
AI_MAX_TOKENS=400
AI_TIMEOUT=20
# Preços (US$ por 1M tokens) usados só para estimar custo das interações.
AI_INPUT_PRICE=1.0
AI_OUTPUT_PRICE=5.0
# Só chama a IA quando a confiança do motor for <= este valor (0–100).
AI_FALLBACK_THRESHOLD=60

# --- Agente Financeiro (chat com tool calling; WhatsApp + portal) ------------
# Modelo do agente (consultas). Haiku = barato/rápido; claude-sonnet-5 p/ mais
# qualidade em insights. Requer AI_PROVIDER=anthropic + AI_API_KEY acima.
AGENT_MODEL=claude-haiku-4-5
AGENT_MAX_TOKENS=1024


# =============================================================================
# OCR — leitura de imagem/PDF escaneado (worker Python: OpenCV + Tesseract).
# =============================================================================
# Provedor: tesseract | null (desligado). Requer python3 + opencv + pytesseract
# + pymupdf + o binário tesseract com o idioma 'por' instalado.
OCR_PROVIDER=null
# Binário do Python. No Windows costuma ser 'python' (não 'python3').
OCR_PYTHON_BIN=python3
# Caminho do script worker (vazio = usa script/ocr/tesseract_worker.py).
OCR_WORKER_PATH=
OCR_LANG=por
OCR_TIMEOUT=30
OCR_DPI=200
# Instale os pacotes Python do worker:
#   python -m pip install opencv-python pytesseract pymupdf numpy
# E o binário do Tesseract (com o idioma 'por').
# --- Windows (tesseract.exe fora do PATH do processo Rails) ------------------
# TESSERACT_CMD: caminho do binário. TESSDATA_PREFIX: pasta com os .traineddata
# (eng/osd/por). Use barras normais (/) para evitar escape no dotenv. Ex.:
# TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe
# TESSDATA_PREFIX=C:/Users/SEU_USUARIO/AppData/Local/aionis-tessdata


# =============================================================================
# OPEN FINANCE — conciliação bancária (opcional; fora do MVP).
# =============================================================================
# Provedor: pluggy | null (desligado).
OPEN_FINANCE_PROVIDER=null
# Onde conseguir: https://dashboard.pluggy.ai  -> Aplicações > Client ID/Secret.
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=
PLUGGY_BASE_URL=
PLUGGY_CONNECT_URL=
PLUGGY_TIMEOUT=20


# =============================================================================
# BANCO DE DADOS (PostgreSQL). Os padrões abaixo servem para dev local.
# =============================================================================
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_HOST=localhost
DB_PORT=5432


# =============================================================================
# CRIPTOGRAFIA (Active Record Encryption) — protege tokens em repouso.
# Em produção é OBRIGATÓRIO definir estas 3 chaves. Gere-as com:
#   bin/rails db:encryption:init
# e cole a saída aqui, DESCOMENTANDO as linhas. (Em dev, deixe comentado: há
# defaults embutidos. NÃO deixe estas variáveis definidas em branco — um valor
# vazio sobrescreve o default e quebra a criptografia.)
# =============================================================================
# AR_ENCRYPTION_PRIMARY_KEY=
# AR_ENCRYPTION_DETERMINISTIC_KEY=
# AR_ENCRYPTION_KEY_DERIVATION_SALT=


# =============================================================================
# INFRA / RAILS (opcionais — só em produção/deploy).
# =============================================================================
# RAILS_MAX_THREADS=5
# RAILS_LOG_LEVEL=info
# PORT=3000
# REDIS_URL=redis://localhost:6379/0
